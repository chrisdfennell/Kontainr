@page "/volumes"
@rendermode InteractiveServer
@inject DockerService Docker
@inject ToastService Toast

<PageTitle>Volumes - Kontainr</PageTitle>

<ConfirmDialog Title="@confirmTitle" Message="@confirmMessage" ConfirmText="@confirmBtnText"
               Visible="@confirmVisible" OnConfirm="ConfirmAction" OnCancel="CancelConfirm" />

<div class="k-topbar">
    <h1>Volumes</h1>
    <p style="font-size: 0.78rem; color: var(--k-text-muted); margin: 0;">Create and manage Docker volumes for persistent storage.</p>
    <div style="display: flex; gap: 0.5rem;">
        <button class="k-btn k-btn-primary" @onclick="ToggleCreate">Create Volume</button>
        <button class="k-btn k-btn-danger" @onclick="RequestPrune" disabled="@pruning">Prune Unused</button>
        <button class="k-btn" @onclick="LoadAsync" disabled="@loading">Refresh</button>
    </div>
</div>

<div class="k-content">
    @if (showCreate)
    {
        <div class="k-card" style="margin-bottom: 1rem;">
            <div class="k-card-header">Create Volume</div>
            <div class="k-card-body">
                <div style="display: flex; gap: 0.75rem; align-items: flex-end; max-width: 500px;">
                    <div style="flex: 1;">
                        <label class="k-form-label">Volume Name</label>
                        <input class="k-form-input" type="text" placeholder="my-volume" @bind="newVolumeName" />
                    </div>
                    <button class="k-btn k-btn-primary" @onclick="CreateVolume" disabled="@(string.IsNullOrWhiteSpace(newVolumeName))">Create</button>
                    <button class="k-btn" @onclick="ToggleCreate">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (error is not null)
    {
        <div class="k-error">@error</div>
    }
    @if (loading)
    {
        <div class="k-spinner">Loading...</div>
    }
    else
    {
        <div class="k-card">
            <table class="k-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Driver</th>
                        <th>Mount Point</th>
                        <th>Created</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vol in volumes)
                    {
                        <tr>
                            <td><strong>@TruncateName(vol.Name)</strong></td>
                            <td><span class="k-badge">@vol.Driver</span></td>
                            <td class="k-mono" style="max-width: 400px; overflow: hidden; text-overflow: ellipsis;">@vol.Mountpoint</td>
                            <td>@(string.IsNullOrEmpty(vol.CreatedAt) ? "-" : vol.CreatedAt)</td>
                            <td style="text-align: right;">
                                <button class="k-btn k-btn-danger" @onclick="() => RequestRemove(vol.Name)" disabled="@(removing == vol.Name)" title="Remove">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (volumes.Count == 0)
        {
            <div style="text-align: center; padding: 3rem; color: var(--k-text-muted);">No volumes found.</div>
        }
    }
</div>

@code {
    private IList<Docker.DotNet.Models.VolumeResponse> volumes = [];
    private bool loading = true;
    private bool showCreate;
    private string newVolumeName = "";
    private string? error;
    private string? removing;
    private bool pruning;

    private bool confirmVisible;
    private string confirmTitle = "", confirmMessage = "", confirmBtnText = "Confirm";
    private Func<Task>? pendingAction;
    private void ShowConfirm(string t, string m, string b, Func<Task> a) { confirmTitle = t; confirmMessage = m; confirmBtnText = b; pendingAction = a; confirmVisible = true; }
    private async Task ConfirmAction() { confirmVisible = false; if (pendingAction is not null) await pendingAction(); pendingAction = null; }
    private void CancelConfirm() { confirmVisible = false; pendingAction = null; }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        loading = true; error = null;
        try { volumes = (await Docker.GetVolumesAsync()).Volumes ?? []; }
        catch (Exception ex) { error = $"Cannot connect to Docker: {ex.Message}"; }
        loading = false;
    }

    private void RequestRemove(string name) =>
        ShowConfirm("Remove Volume", $"Remove volume \"{TruncateName(name)}\"? Data will be lost.", "Remove", async () =>
        {
            removing = name;
            try { await Docker.RemoveVolumeAsync(name); Toast.Success("Volume removed"); await LoadAsync(); }
            catch (Exception ex) { Toast.Error($"Failed: {ex.Message}"); }
            removing = null;
        });

    private void RequestPrune() =>
        ShowConfirm("Prune Volumes", "Remove all unused volumes? Data in unused volumes will be permanently lost.", "Prune", async () =>
        {
            pruning = true;
            try { var r = await Docker.PruneVolumesAsync(); Toast.Success($"Pruned {r.VolumesDeleted?.Count ?? 0} volumes"); await LoadAsync(); }
            catch (Exception ex) { Toast.Error($"Prune failed: {ex.Message}"); }
            pruning = false;
        });

    private void ToggleCreate() { showCreate = !showCreate; newVolumeName = ""; }

    private async Task CreateVolume()
    {
        if (string.IsNullOrWhiteSpace(newVolumeName)) return;
        try
        {
            await Docker.CreateVolumeAsync(newVolumeName.Trim());
            Toast.Success($"Volume '{newVolumeName}' created");
            showCreate = false; newVolumeName = "";
            await LoadAsync();
        }
        catch (Exception ex) { Toast.Error($"Failed: {ex.Message}"); }
    }

    private static string TruncateName(string name) =>
        name.Length > 30 ? name[..12] + "..." + name[^8..] : name;
}
