@page "/terminal/{ConnectionId}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject SshSessionManager SessionManager
@inject SshSettingsService SshSettings
@inject ToastService Toast
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Terminal - Kontainr</PageTitle>

<div class="k-topbar">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
        <a href="/terminals" class="k-btn" style="text-decoration: none;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back
        </a>
        <h1>@(config?.Name ?? "Terminal")</h1>
        @if (connected)
        {
            <span class="k-badge" style="background: rgba(63, 185, 80, 0.15); color: var(--k-green);">Connected</span>
        }
    </div>
    <div class="k-btn-group">
        @if (connected)
        {
            <button class="k-btn k-btn-danger" @onclick="Disconnect">Disconnect</button>
        }
        else
        {
            <button class="k-btn k-btn-success" @onclick="Connect" disabled="@connecting">
                @(connecting ? "Connecting..." : "Connect")
            </button>
        }
    </div>
</div>

<div class="k-content">
    @if (error is not null)
    {
        <div class="k-error">@error</div>
    }

    <div class="k-card">
        <div class="k-card-header">
            <span>@(config?.Username)@@@(config?.Host):@(config?.Port)</span>
            <span style="font-size: 0.75rem; color: var(--k-text-muted);">Interactive SSH Shell</span>
        </div>
        <div id="ssh-xterm-container" style="padding: 4px; background: #010409; border-radius: 0 0 8px 8px; min-height: 400px;"></div>
    </div>
</div>

@code {
    [Parameter] public string ConnectionId { get; set; } = "";

    private SshConnectionConfig? config;
    private bool connected;
    private bool connecting;
    private string? error;
    private CancellationTokenSource? readCts;
    private DotNetObjectReference<SshTerminal>? dotnetRef;

    protected override void OnInitialized()
    {
        config = SshSettings.GetConnection(ConnectionId);
        if (config is null)
            error = "Connection not found. Go to Settings to configure SSH connections.";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && config is not null)
            await Connect();
    }

    private async Task Connect()
    {
        connecting = true; error = null;
        StateHasChanged();

        try
        {
            await Task.Run(() => SessionManager.GetOrCreateSession(ConnectionId));
            connected = true;

            dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("kontainr.initTerminal", "ssh-xterm-container", dotnetRef);

            // Start reading output from the SSH shell
            readCts = new CancellationTokenSource();
            _ = ReadOutputLoop(readCts.Token);

            Toast.Success($"Connected to {config!.Name}");
        }
        catch (Exception ex)
        {
            error = $"Connection failed: {ex.Message}";
            Toast.Error("Connection failed");
        }

        connecting = false;
        StateHasChanged();
    }

    private async Task ReadOutputLoop(CancellationToken ct)
    {
        try
        {
            var session = SessionManager.GetOrCreateSession(ConnectionId);
            var shell = session.GetShellStream();
            if (shell is null) return;

            var buffer = new byte[4096];
            while (!ct.IsCancellationRequested)
            {
                if (shell.DataAvailable)
                {
                    var count = shell.Read(buffer, 0, buffer.Length);
                    if (count > 0)
                    {
                        var text = System.Text.Encoding.UTF8.GetString(buffer, 0, count);
                        await InvokeAsync(async () =>
                        {
                            await JS.InvokeVoidAsync("kontainr.writeTerminal", "ssh-xterm-container", text);
                        });
                    }
                }
                else
                {
                    await Task.Delay(30, ct);
                }
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            await InvokeAsync(() =>
            {
                error = $"Connection lost: {ex.Message}";
                connected = false;
                StateHasChanged();
            });
        }
    }

    [JSInvokable]
    public Task OnTerminalInput(string data)
    {
        if (!connected) return Task.CompletedTask;
        try
        {
            var session = SessionManager.GetOrCreateSession(ConnectionId);
            session.WriteRaw(data);
        }
        catch { }
        return Task.CompletedTask;
    }

    private void Disconnect()
    {
        readCts?.Cancel();
        SessionManager.DisconnectSession(ConnectionId);
        connected = false;
        Toast.Info("Disconnected");
    }

    public async ValueTask DisposeAsync()
    {
        readCts?.Cancel();
        readCts?.Dispose();
        dotnetRef?.Dispose();
        try { await JS.InvokeVoidAsync("kontainr.disposeTerminal", "ssh-xterm-container"); } catch { }
    }
}
