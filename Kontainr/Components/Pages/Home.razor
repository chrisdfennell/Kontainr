@page "/"
@rendermode InteractiveServer
@inject DockerService Docker
@inject DockerServiceFactory DockerFactory
@inject SshSettingsService Settings
@inject ContainerEventService Events
@implements IDisposable

<PageTitle>Dashboard - Kontainr</PageTitle>

<div class="k-topbar">
    <h1>Dashboard</h1>
    <div style="display: flex; gap: 0.75rem; align-items: center;">
        @if (allHostIds.Count > 1)
        {
            <select class="k-select" @bind="selectedHostId" @bind:after="LoadAsync">
                <option value="">All Hosts</option>
                @foreach (var h in hostConfigs)
                {
                    <option value="@h.Id">@h.Name</option>
                }
            </select>
        }
        <span class="k-auto-refresh-indicator @(autoRefresh ? "active" : "")"></span>
        <label style="font-size: 0.8rem; display: flex; align-items: center; gap: 0.4rem; color: var(--k-text-muted);">
            <input type="checkbox" @bind="autoRefresh" @bind:after="ToggleAutoRefresh" /> Auto-refresh
        </label>
        <select class="k-select" @bind="refreshInterval" @bind:after="ToggleAutoRefresh" disabled="@(!autoRefresh)">
            <option value="3">3s</option>
            <option value="5">5s</option>
            <option value="10">10s</option>
            <option value="30">30s</option>
        </select>
        <button class="k-btn" @onclick="LoadAsync" disabled="@loading">Refresh</button>
    </div>
</div>

<div class="k-content">
    @if (alerts.Count > 0)
    {
        <div class="k-alert-banner">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;">
                <span style="font-weight: 600;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--k-red)" stroke-width="2" style="vertical-align: -3px; margin-right: 0.3rem;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    @alerts.Count Alert(s)
                </span>
                <button class="k-btn" style="font-size: 0.75rem; padding: 0.2rem 0.5rem;" @onclick="DismissAllAlerts">Dismiss All</button>
            </div>
            @foreach (var alert in alerts)
            {
                <div class="k-alert-item">
                    <span>
                        <strong>@alert.ContainerName</strong>
                        @if (alert.HostId != "local")
                        {
                            <span class="k-badge" style="margin-left: 0.3rem; font-size: 0.65rem;">@alert.HostName</span>
                        }
                        — @alert.Message
                    </span>
                    <span style="font-size: 0.72rem; color: var(--k-text-muted);">@alert.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                </div>
            }
        </div>
    }

    @if (error is not null)
    {
        <div class="k-error">@error</div>
    }

    @if (loading && containers.Count == 0)
    {
        <div class="k-spinner">Loading...</div>
    }
    else
    {
        <div class="k-stat-grid">
            <div class="k-stat-card">
                <div class="k-stat-label">Running</div>
                <div class="k-stat-value green">@runningCount</div>
            </div>
            <div class="k-stat-card">
                <div class="k-stat-label">Stopped</div>
                <div class="k-stat-value red">@stoppedCount</div>
            </div>
            <div class="k-stat-card">
                <div class="k-stat-label">Images</div>
                <div class="k-stat-value blue">@imageCount</div>
            </div>
            <div class="k-stat-card">
                <div class="k-stat-label">Volumes</div>
                <div class="k-stat-value yellow">@volumeCount</div>
            </div>
            @if (allHostIds.Count > 1)
            {
                <div class="k-stat-card">
                    <div class="k-stat-label">Hosts</div>
                    <div class="k-stat-value" style="color: var(--k-accent);">@allHostIds.Count</div>
                </div>
            }
        </div>

        @if (favoriteContainers.Count > 0)
        {
            <div class="k-card" style="margin-bottom: 1rem;">
                <div class="k-card-header">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--k-yellow)" stroke="var(--k-yellow)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    Favorites
                </div>
                <table class="k-table">
                    <thead>
                        <tr>
                            <th class="col-name">Name</th>
                            <th class="col-image">Image</th>
                            <th class="col-status">Status</th>
                            @if (allHostIds.Count > 1)
                            {
                                <th class="col-host">Host</th>
                            }
                            <th class="col-cpu">CPU</th>
                            <th class="col-mem">Memory</th>
                            <th class="col-ports">Ports</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in favoriteContainers)
                        {
                            <tr class="k-clickable" @onclick="() => NavigateToContainer(c)">
                                <td class="col-name">
                                    <span class="k-fav-star" @onclick:stopPropagation="true" @onclick="() => ToggleFav(c.Name)" title="Unpin">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--k-yellow)" stroke="var(--k-yellow)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                    </span>
                                    @c.Name
                                    @if (Docker.IsSelf(c.Id))
                                    {
                                        <span class="k-badge" style="margin-left: 0.4rem; background: rgba(88,166,255,0.15); color: var(--k-accent); font-size: 0.65rem;">self</span>
                                    }
                                </td>
                                <td class="col-image k-mono">@c.Image</td>
                                <td class="col-status">
                                    <span class="k-status @c.StateClass">
                                        <span class="k-status-dot"></span>
                                        @c.Status
                                    </span>
                                </td>
                                @if (allHostIds.Count > 1)
                                {
                                    <td class="col-host">@c.HostName</td>
                                }
                                <td class="col-cpu k-mono">@(c.IsRunning ? GetCpu(c) : "-")</td>
                                <td class="col-mem k-mono">@(c.IsRunning ? GetMemory(c) : "-")</td>
                                <td class="col-ports k-mono">@c.PortDisplay</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (containers.Count > 0)
        {
            <div class="k-card">
                <div class="k-card-header">All Containers</div>
                <table class="k-table">
                    <thead>
                        <tr>
                            <th class="col-name">Name</th>
                            <th class="col-image">Image</th>
                            <th class="col-status">Status</th>
                            @if (allHostIds.Count > 1)
                            {
                                <th class="col-host">Host</th>
                            }
                            <th class="col-cpu">CPU</th>
                            <th class="col-mem">Memory</th>
                            <th class="col-ports">Ports</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in containers)
                        {
                            <tr class="k-clickable" @onclick="() => NavigateToContainer(c)">
                                <td class="col-name">
                                    <span class="k-fav-star" @onclick:stopPropagation="true" @onclick="() => ToggleFav(c.Name)" title="@(favorites.Contains(c.Name) ? "Unpin" : "Pin to favorites")">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="@(favorites.Contains(c.Name) ? "var(--k-yellow)" : "none")" stroke="@(favorites.Contains(c.Name) ? "var(--k-yellow)" : "var(--k-text-muted)")" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                    </span>
                                    @c.Name
                                    @if (Docker.IsSelf(c.Id))
                                    {
                                        <span class="k-badge" style="margin-left: 0.4rem; background: rgba(88,166,255,0.15); color: var(--k-accent); font-size: 0.65rem;">self</span>
                                    }
                                </td>
                                <td class="col-image k-mono">@c.Image</td>
                                <td class="col-status">
                                    <span class="k-status @c.StateClass">
                                        <span class="k-status-dot"></span>
                                        @c.Status
                                    </span>
                                </td>
                                @if (allHostIds.Count > 1)
                                {
                                    <td class="col-host">@c.HostName</td>
                                }
                                <td class="col-cpu k-mono">@(c.IsRunning ? GetCpu(c) : "-")</td>
                                <td class="col-mem k-mono">@(c.IsRunning ? GetMemory(c) : "-")</td>
                                <td class="col-ports k-mono">@c.PortDisplay</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private List<ContainerViewModel> containers = [];
    private List<ContainerViewModel> favoriteContainers = [];
    private List<ContainerAlert> alerts = [];
    private HashSet<string> favorites = [];
    private Dictionary<string, (double cpu, long memUsage, long memLimit)> stats = [];
    private IReadOnlyList<string> allHostIds = [];
    private IReadOnlyList<Models.DockerHostConfig> hostConfigs = [];
    private string selectedHostId = "";
    private int runningCount, stoppedCount, imageCount, volumeCount;
    private bool loading = true;
    private string? error;
    private bool autoRefresh = true;
    private int refreshInterval = 5;
    private Timer? refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        favorites = Settings.GetFavorites();
        allHostIds = DockerFactory.GetAllHostIds();
        hostConfigs = DockerFactory.GetAllHostConfigs();
        await LoadAsync();
        StartAutoRefresh();
    }

    private void DismissAllAlerts()
    {
        Events.DismissAll();
        alerts = [];
    }

    private async Task LoadAsync()
    {
        loading = true;
        error = null;
        try
        {
            var allContainers = new List<ContainerViewModel>();
            var hostsToQuery = string.IsNullOrEmpty(selectedHostId) ? allHostIds : [selectedHostId];

            foreach (var hostId in hostsToQuery)
            {
                try
                {
                    var docker = DockerFactory.GetService(hostId);
                    var config = DockerFactory.GetHostConfig(hostId);
                    var rawContainers = await docker.GetContainersAsync();
                    allContainers.AddRange(rawContainers.Select(c => ContainerViewModel.FromApi(c, hostId, config.Name)));
                }
                catch (Exception ex)
                {
                    error = (error is null ? "" : error + "\n") + $"{hostId}: {ex.Message}";
                }
            }

            containers = allContainers.OrderBy(c => c.Name).ToList();
            favoriteContainers = containers.Where(c => favorites.Contains(c.Name)).ToList();
            runningCount = containers.Count(c => c.IsRunning);
            stoppedCount = containers.Count(c => c.IsExited);

            // Get image/volume counts from local (or selected host)
            var countHost = string.IsNullOrEmpty(selectedHostId) ? "local" : selectedHostId;
            var countDocker = DockerFactory.GetService(countHost);
            imageCount = (await countDocker.GetImagesAsync()).Count;
            volumeCount = (await countDocker.GetVolumesAsync()).Volumes?.Count ?? 0;

            // Fetch stats for running containers
            var running = containers.Where(c => c.IsRunning).ToList();
            var statsTasks = running.Select(async c =>
            {
                var docker = DockerFactory.GetService(c.HostId);
                var s = await docker.GetContainerStatsOnceAsync(c.Id);
                return (c.Id, c.HostId, Stats: s);
            });
            var results = await Task.WhenAll(statsTasks);
            var newStats = new Dictionary<string, (double cpu, long memUsage, long memLimit)>();
            foreach (var r in results)
            {
                if (r.Stats is not null)
                {
                    var key = r.HostId == "local" ? r.Id : $"{r.HostId}:{r.Id}";
                    newStats[key] = ComputeStats(r.Stats);
                }
            }
            stats = newStats;
            alerts = Events.GetAlerts();
        }
        catch (Exception ex)
        {
            error = $"Cannot connect to Docker: {ex.Message}";
        }
        loading = false;
    }

    private void ToggleFav(string name)
    {
        Settings.ToggleFavorite(name);
        favorites = Settings.GetFavorites();
        favoriteContainers = containers.Where(c => favorites.Contains(c.Name)).ToList();
    }

    private static (double cpu, long memUsage, long memLimit) ComputeStats(Docker.DotNet.Models.ContainerStatsResponse s)
    {
        double cpu = 0;
        var cpuDelta = (double)(s.CPUStats.CPUUsage.TotalUsage - s.PreCPUStats.CPUUsage.TotalUsage);
        var sysDelta = (double)(s.CPUStats.SystemUsage - s.PreCPUStats.SystemUsage);
        var cpuCount = s.CPUStats.OnlineCPUs > 0 ? s.CPUStats.OnlineCPUs : (ulong)(s.CPUStats.CPUUsage.PercpuUsage?.Count ?? 1);
        if (sysDelta > 0 && cpuDelta >= 0)
            cpu = (cpuDelta / sysDelta) * cpuCount * 100.0;
        return (cpu, (long)s.MemoryStats.Usage, (long)s.MemoryStats.Limit);
    }

    private string GetCpu(ContainerViewModel c)
    {
        var key = c.HostId == "local" ? c.Id : $"{c.HostId}:{c.Id}";
        return stats.TryGetValue(key, out var s) ? $"{s.cpu:F1}%" : "...";
    }

    private string GetMemory(ContainerViewModel c)
    {
        var key = c.HostId == "local" ? c.Id : $"{c.HostId}:{c.Id}";
        return stats.TryGetValue(key, out var s) ? $"{FormatBytes(s.memUsage)} / {FormatBytes(s.memLimit)}" : "...";
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F0} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }

    private void StartAutoRefresh()
    {
        refreshTimer?.Dispose();
        if (autoRefresh)
        {
            refreshTimer = new Timer(async _ =>
            {
                await InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
            }, null, TimeSpan.FromSeconds(refreshInterval), TimeSpan.FromSeconds(refreshInterval));
        }
    }

    private void ToggleAutoRefresh() => StartAutoRefresh();
    private void NavigateToContainer(ContainerViewModel c) => Nav.NavigateTo($"/containers/{c.HostId}/{c.Id}");
    public void Dispose() => refreshTimer?.Dispose();
}
