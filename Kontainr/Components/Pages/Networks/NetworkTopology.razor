@page "/topology"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject DockerService Docker
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Network Topology - Kontainr</PageTitle>

<div class="k-topbar">
    <h1>Network Topology</h1>
    <div style="display: flex; gap: 0.5rem; align-items: center;">
        <select class="k-form-input" style="width: auto; padding: 0.35rem 0.5rem; font-size: 0.8rem;" @bind="selectedLayout" @bind:after="ApplyLayout">
            <option value="cose">Force-directed</option>
            <option value="circle">Circle</option>
            <option value="breadthfirst">Hierarchical</option>
            <option value="grid">Grid</option>
        </select>
        <button class="k-btn" @onclick="ResetView">Fit View</button>
        <button class="k-btn" @onclick="Refresh" disabled="@loading">Refresh</button>
    </div>
</div>

<div class="k-content" style="padding: 0; height: calc(100vh - 49px); position: relative;">
    @if (error is not null)
    {
        <div class="k-error" style="margin: 1rem;">@error</div>
    }
    @if (loading)
    {
        <div style="position: absolute; top: 1rem; left: 50%; transform: translateX(-50%); z-index: 10;">
            <span class="k-badge" style="background: rgba(88,166,255,0.15); color: var(--k-accent); padding: 0.4rem 0.8rem;">Loading topology...</span>
        </div>
    }
    @if (stats is not null)
    {
        <div style="position: absolute; bottom: 1rem; left: 1rem; z-index: 10; display: flex; gap: 0.5rem;">
            <span class="k-badge" style="background: rgba(188,140,255,0.15); color: var(--k-purple);">@stats.Value.NetworkCount networks</span>
            <span class="k-badge" style="background: rgba(63,185,80,0.15); color: var(--k-green);">@stats.Value.RunningCount running</span>
            @if (stats.Value.StoppedCount > 0)
            {
                <span class="k-badge" style="background: rgba(248,81,73,0.15); color: var(--k-red);">@stats.Value.StoppedCount stopped</span>
            }
        </div>
    }
    <div style="position: absolute; top: 0.75rem; right: 0.75rem; z-index: 10; background: rgba(22,27,34,0.9); border: 1px solid var(--k-border); border-radius: 8px; padding: 0.6rem 0.8rem; font-size: 0.72rem; color: var(--k-text-muted); line-height: 1.6;">
        <div style="margin-bottom: 0.25rem; font-weight: 600; color: var(--k-text); font-size: 0.75rem;">Legend</div>
        <div style="display: flex; align-items: center; gap: 0.4rem;">
            <span style="display: inline-block; width: 12px; height: 12px; transform: rotate(45deg); border: 2px solid var(--k-purple); background: #161b22;"></span>
            Network
        </div>
        <div style="display: flex; align-items: center; gap: 0.4rem;">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 3px; border: 2px solid var(--k-green); background: #0d2818;"></span>
            Running container
        </div>
        <div style="display: flex; align-items: center; gap: 0.4rem;">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 3px; border: 2px dashed var(--k-red); background: #1c1012; opacity: 0.6;"></span>
            Stopped container
        </div>
        <div style="display: flex; align-items: center; gap: 0.4rem;">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 3px; border: 1.5px solid var(--k-accent); background: #1a3a52;"></span>
            Port mapping
        </div>
        <div style="margin-top: 0.3rem; font-size: 0.68rem; color: var(--k-text-muted);">Click container to view details</div>
        <div style="font-size: 0.68rem; color: var(--k-text-muted);">Hover to highlight connections</div>
    </div>
    <div id="cy-topology" style="width: 100%; height: 100%;"></div>
</div>

@code {
    private bool loading = true;
    private string? error;
    private string selectedLayout = "cose";
    private DotNetObjectReference<NetworkTopology>? dotnetRef;
    private (int NetworkCount, int RunningCount, int StoppedCount)? stats;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotnetRef = DotNetObjectReference.Create(this);
            await LoadAndRender();
        }
    }

    private async Task LoadAndRender()
    {
        loading = true;
        error = null;
        StateHasChanged();

        try
        {
            var networks = await Docker.GetNetworksAsync();
            var containers = await Docker.GetContainersAsync(all: true);
            var containerLookup = containers.ToDictionary(c => c.ID, c => c);

            var elements = BuildElements(networks, containerLookup);
            await JS.InvokeVoidAsync("kontainr.initTopology", "cy-topology", elements, dotnetRef);
        }
        catch (Exception ex)
        {
            error = $"Cannot connect to Docker: {ex.Message}";
        }

        loading = false;
        StateHasChanged();
    }

    private List<object> BuildElements(IList<Docker.DotNet.Models.NetworkResponse> networks,
        Dictionary<string, Docker.DotNet.Models.ContainerListResponse> containerLookup)
    {
        var elements = new List<object>();
        var addedContainers = new HashSet<string>();
        var addedPorts = new HashSet<string>();
        int runningCount = 0, stoppedCount = 0;

        foreach (var net in networks)
        {
            // Network node
            var subnet = net.IPAM?.Config?.FirstOrDefault()?.Subnet;
            var netLabel = net.Name;
            if (subnet is not null) netLabel += $"\n{subnet}";
            netLabel += $"\n{net.Driver}";
            var netNodeId = $"net-{net.ID[..12]}";

            elements.Add(new
            {
                data = new
                {
                    id = netNodeId,
                    label = netLabel,
                    nodeType = "network",
                    driver = net.Driver ?? "",
                    color = "" // filled by JS
                }
            });

            // Container nodes connected to this network
            if (net.Containers is not null)
            {
                foreach (var (containerId, endpoint) in net.Containers)
                {
                    var cNodeId = $"c-{containerId[..12]}";

                    // Add container node (only once, even if in multiple networks)
                    if (!addedContainers.Contains(containerId))
                    {
                        addedContainers.Add(containerId);

                        var name = endpoint.Name;
                        var state = "exited";
                        List<(ushort pub, ushort priv, string proto)>? ports = null;

                        if (containerLookup.TryGetValue(containerId, out var container))
                        {
                            name = container.Names.FirstOrDefault()?.TrimStart('/') ?? name;
                            state = container.State;
                            ports = container.Ports?
                                .Where(p => p.PublicPort > 0)
                                .Select(p => (p.PublicPort, p.PrivatePort, p.Type))
                                .ToList();
                        }

                        if (state == "running") runningCount++; else stoppedCount++;

                        elements.Add(new
                        {
                            data = new
                            {
                                id = cNodeId,
                                label = name,
                                nodeType = "container",
                                status = state,
                                containerId = containerId
                            }
                        });

                        // Port badge nodes (one per unique port mapping)
                        if (ports is not null)
                        {
                            foreach (var (pub, priv, proto) in ports)
                            {
                                var portKey = $"{containerId[..12]}-{pub}-{priv}";
                                if (addedPorts.Add(portKey))
                                {
                                    var portNodeId = $"p-{portKey}";
                                    elements.Add(new
                                    {
                                        data = new
                                        {
                                            id = portNodeId,
                                            label = $":{pub} -> :{priv}/{proto}",
                                            nodeType = "port"
                                        }
                                    });
                                    elements.Add(new
                                    {
                                        data = new
                                        {
                                            id = $"ep-{portKey}",
                                            source = cNodeId,
                                            target = portNodeId,
                                            edgeType = "port",
                                            label = "",
                                            targetNetId = "",
                                            color = ""
                                        }
                                    });
                                }
                            }
                        }
                    }

                    // Edge: container -> network (with IP label)
                    var ip = endpoint.IPv4Address;
                    if (!string.IsNullOrEmpty(ip) && ip.Contains('/'))
                        ip = ip.Split('/')[0];

                    elements.Add(new
                    {
                        data = new
                        {
                            id = $"e-{containerId[..12]}-{net.ID[..12]}",
                            source = cNodeId,
                            target = netNodeId,
                            edgeType = "network",
                            label = ip ?? "",
                            targetNetId = netNodeId,
                            color = "" // filled by JS
                        }
                    });
                }
            }
        }

        stats = (networks.Count, runningCount, stoppedCount);
        return elements;
    }

    private async Task Refresh()
    {
        loading = true;
        StateHasChanged();

        try
        {
            var networks = await Docker.GetNetworksAsync();
            var containers = await Docker.GetContainersAsync(all: true);
            var containerLookup = containers.ToDictionary(c => c.ID, c => c);
            var elements = BuildElements(networks, containerLookup);
            await JS.InvokeVoidAsync("kontainr.updateTopology", (object)elements);
        }
        catch (Exception ex)
        {
            error = $"Refresh failed: {ex.Message}";
        }

        loading = false;
        StateHasChanged();
    }

    private async Task ApplyLayout()
    {
        await JS.InvokeVoidAsync("kontainr.setTopologyLayout", selectedLayout);
    }

    private async Task ResetView()
    {
        await JS.InvokeVoidAsync("kontainr.resetTopologyView");
    }

    [JSInvokable]
    public void NavigateToContainer(string containerId)
    {
        Nav.NavigateTo($"/containers/{containerId}");
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("kontainr.disposeTopology");
        }
        catch { }
        dotnetRef?.Dispose();
    }
}
