@page "/networks"
@rendermode InteractiveServer
@inject DockerService Docker
@inject ToastService Toast

<PageTitle>Networks - Kontainr</PageTitle>

<ConfirmDialog Title="@confirmTitle" Message="@confirmMessage" ConfirmText="@confirmBtnText"
               Visible="@confirmVisible" OnConfirm="ConfirmAction" OnCancel="CancelConfirm" />

<div class="k-topbar">
    <h1>Networks</h1>
    <p style="font-size: 0.78rem; color: var(--k-text-muted); margin: 0;">Create and manage Docker networks.</p>
    <div style="display: flex; gap: 0.5rem;">
        <button class="k-btn k-btn-primary" @onclick="ToggleCreate">Create Network</button>
        <button class="k-btn k-btn-danger" @onclick="RequestPrune" disabled="@pruning">Prune Unused</button>
        <button class="k-btn" @onclick="LoadAsync" disabled="@loading">Refresh</button>
    </div>
</div>

<div class="k-content">
    @if (showCreate)
    {
        <div class="k-card" style="margin-bottom: 1rem;">
            <div class="k-card-header">Create Network</div>
            <div class="k-card-body">
                <div style="display: flex; gap: 0.75rem; align-items: flex-end; max-width: 500px;">
                    <div style="flex: 1;">
                        <label class="k-form-label">Network Name</label>
                        <input class="k-form-input" type="text" placeholder="my-network" @bind="newNetName" />
                    </div>
                    <div style="width: 120px;">
                        <label class="k-form-label">Driver</label>
                        <select class="k-form-input" @bind="newNetDriver">
                            <option value="bridge">bridge</option>
                            <option value="host">host</option>
                            <option value="overlay">overlay</option>
                            <option value="macvlan">macvlan</option>
                        </select>
                    </div>
                    <button class="k-btn k-btn-primary" @onclick="CreateNetwork" disabled="@(string.IsNullOrWhiteSpace(newNetName))">Create</button>
                    <button class="k-btn" @onclick="ToggleCreate">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (error is not null)
    {
        <div class="k-error">@error</div>
    }
    @if (loading)
    {
        <div class="k-spinner">Loading...</div>
    }
    else
    {
        <div class="k-card">
            <table class="k-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>ID</th>
                        <th>Driver</th>
                        <th>Scope</th>
                        <th>Subnet</th>
                        <th>Containers</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var net in networks)
                    {
                        var subnet = net.IPAM?.Config?.FirstOrDefault()?.Subnet ?? "-";
                        var containerCount = net.Containers?.Count ?? 0;
                        var isBuiltIn = net.Name is "bridge" or "host" or "none";
                        <tr>
                            <td>
                                <strong>@net.Name</strong>
                                @if (isBuiltIn)
                                {
                                    <span class="k-badge" style="margin-left: 0.5rem; background: rgba(139,148,158,0.15); color: var(--k-text-muted);">built-in</span>
                                }
                            </td>
                            <td class="k-mono">@net.ID[..12]</td>
                            <td><span class="k-badge">@net.Driver</span></td>
                            <td>@net.Scope</td>
                            <td class="k-mono">@subnet</td>
                            <td>@containerCount</td>
                            <td style="text-align: right;">
                                @if (!isBuiltIn)
                                {
                                    <button class="k-btn k-btn-danger" @onclick="() => RequestRemove(net.ID, net.Name)" disabled="@(removing == net.ID)" title="Remove">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (networks.Count == 0)
        {
            <div style="text-align: center; padding: 3rem; color: var(--k-text-muted);">No networks found.</div>
        }
    }
</div>

@code {
    private IList<Docker.DotNet.Models.NetworkResponse> networks = [];
    private bool loading = true;
    private bool showCreate;
    private string newNetName = "";
    private string newNetDriver = "bridge";
    private string? error;
    private string? removing;
    private bool pruning;

    private bool confirmVisible;
    private string confirmTitle = "", confirmMessage = "", confirmBtnText = "Confirm";
    private Func<Task>? pendingAction;
    private void ShowConfirm(string t, string m, string b, Func<Task> a) { confirmTitle = t; confirmMessage = m; confirmBtnText = b; pendingAction = a; confirmVisible = true; }
    private async Task ConfirmAction() { confirmVisible = false; if (pendingAction is not null) await pendingAction(); pendingAction = null; }
    private void CancelConfirm() { confirmVisible = false; pendingAction = null; }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        loading = true; error = null;
        try { networks = await Docker.GetNetworksAsync(); }
        catch (Exception ex) { error = $"Cannot connect to Docker: {ex.Message}"; }
        loading = false;
    }

    private void RequestRemove(string id, string name) =>
        ShowConfirm("Remove Network", $"Remove network \"{name}\"?", "Remove", async () =>
        {
            removing = id;
            try { await Docker.RemoveNetworkAsync(id); Toast.Success("Network removed"); await LoadAsync(); }
            catch (Exception ex) { Toast.Error($"Failed: {ex.Message}"); }
            removing = null;
        });

    private void ToggleCreate() { showCreate = !showCreate; newNetName = ""; }

    private async Task CreateNetwork()
    {
        if (string.IsNullOrWhiteSpace(newNetName)) return;
        try
        {
            await Docker.CreateNetworkAsync(newNetName.Trim(), newNetDriver);
            Toast.Success($"Network '{newNetName}' created");
            showCreate = false; newNetName = "";
            await LoadAsync();
        }
        catch (Exception ex) { Toast.Error($"Failed: {ex.Message}"); }
    }

    private void RequestPrune() =>
        ShowConfirm("Prune Networks", "Remove all unused networks?", "Prune", async () =>
        {
            pruning = true;
            try { var r = await Docker.PruneNetworksAsync(); Toast.Success($"Pruned {r.NetworksDeleted?.Count ?? 0} networks"); await LoadAsync(); }
            catch (Exception ex) { Toast.Error($"Prune failed: {ex.Message}"); }
            pruning = false;
        });
}
