@page "/settings"
@rendermode InteractiveServer
@inject SshSettingsService SshSettings
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Settings - Kontainr</PageTitle>

<ConfirmDialog Title="@confirmTitle" Message="@confirmMessage" ConfirmText="@confirmBtnText"
               Visible="@confirmVisible" OnConfirm="ConfirmAction" OnCancel="CancelConfirm" />

<div class="k-topbar">
    <h1>Settings</h1>
</div>

<div class="k-content">
    <div class="k-card" style="margin-bottom: 1.5rem;">
        <div class="k-card-header">General</div>
        <div class="k-card-body">
            <div style="max-width: 400px;">
                <label class="k-form-label">Docker Host URL</label>
                <div style="display: flex; gap: 0.5rem;">
                    <input class="k-form-input" type="text" placeholder="fennell-nas" @bind="hostUrl" />
                    <button class="k-btn k-btn-primary" @onclick="SaveHostUrl">Save</button>
                </div>
                <span style="font-size: 0.72rem; color: var(--k-text-muted);">Used for port links, e.g. http://@(hostUrl):8080. Use hostname or IP, no http:// prefix.</span>
            </div>
        </div>
    </div>

    <div class="k-card" style="margin-bottom: 1.5rem;">
        <div class="k-card-header">
            SSH Connections
            <button class="k-btn k-btn-primary" @onclick="ShowAddForm">Add Connection</button>
        </div>

        @if (showForm)
        {
            <div class="k-card-body" style="border-bottom: 1px solid var(--k-border);">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; max-width: 600px;">
                    <div>
                        <label class="k-form-label">Name</label>
                        <input class="k-form-input" type="text" placeholder="My NAS" @bind="editName" />
                    </div>
                    <div>
                        <label class="k-form-label">Host</label>
                        <input class="k-form-input" type="text" placeholder="192.168.1.100 or hostname" @bind="editHost" />
                    </div>
                    <div>
                        <label class="k-form-label">Port</label>
                        <input class="k-form-input" type="number" @bind="editPort" />
                    </div>
                    <div>
                        <label class="k-form-label">Username</label>
                        <input class="k-form-input" type="text" placeholder="admin" @bind="editUsername" />
                    </div>
                    <div style="grid-column: span 2;">
                        <label class="k-form-label">Password</label>
                        <input class="k-form-input" type="password" placeholder="@(editId is not null ? "(unchanged)" : "Enter password")" @bind="editPassword" />
                    </div>
                    <div style="grid-column: span 2;">
                        <label class="k-form-label">Init Commands</label>
                        <input class="k-form-input" type="text" placeholder="e.g. Q, Y (comma-separated commands sent on connect)" @bind="editInitCommands" />
                        <span style="font-size: 0.7rem; color: var(--k-text-muted);">Commands sent after login to escape menus. Separate with commas. Example for QNAP: Q, Y</span>
                    </div>
                </div>
                <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                    <button class="k-btn k-btn-primary" @onclick="SaveConnection"
                            disabled="@(string.IsNullOrWhiteSpace(editName) || string.IsNullOrWhiteSpace(editHost) || string.IsNullOrWhiteSpace(editUsername))">
                        @(editId is not null ? "Update" : "Save")
                    </button>
                    <button class="k-btn" @onclick="CancelForm">Cancel</button>
                    @if (!string.IsNullOrEmpty(testResult))
                    {
                        <span style="align-self: center; font-size: 0.8rem; color: @(testSuccess ? "var(--k-green)" : "var(--k-red)");">@testResult</span>
                    }
                    <button class="k-btn" @onclick="TestConnection" disabled="@testing"
                            style="margin-left: auto;">
                        @(testing ? "Testing..." : "Test Connection")
                    </button>
                </div>
            </div>
        }

        @if (connections.Count > 0)
        {
            <table class="k-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Host</th>
                        <th>Port</th>
                        <th>Username</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var conn in connections)
                    {
                        <tr>
                            <td><strong>@conn.Name</strong></td>
                            <td class="k-mono">@conn.Host</td>
                            <td>@conn.Port</td>
                            <td class="k-mono">@conn.Username</td>
                            <td style="text-align: right;">
                                <div class="k-btn-group">
                                    <a href="/terminal/@conn.Id" class="k-btn k-btn-success" style="text-decoration: none;">Connect</a>
                                    <button class="k-btn" @onclick="() => EditConnection(conn)">Edit</button>
                                    <button class="k-btn k-btn-danger" @onclick="() => RequestDelete(conn)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (!showForm)
        {
            <div style="text-align: center; padding: 2rem; color: var(--k-text-muted);">
                No SSH connections configured. Click "Add Connection" to get started.
            </div>
        }
    </div>

    <div class="k-card" style="margin-bottom: 1.5rem;">
        <div class="k-card-header">Backup & Restore</div>
        <div class="k-card-body">
            <div style="display: flex; gap: 0.75rem; align-items: flex-start; flex-wrap: wrap;">
                <div>
                    <p style="font-size: 0.8rem; color: var(--k-text-muted); margin: 0 0 0.5rem;">Export all settings (SSH connections, favorites, host URL) to a JSON file.</p>
                    <button class="k-btn k-btn-primary" @onclick="ExportSettings">Export Settings</button>
                </div>
                <div>
                    <p style="font-size: 0.8rem; color: var(--k-text-muted); margin: 0 0 0.5rem;">Import settings from a previously exported JSON file.</p>
                    <label class="k-btn" style="cursor: pointer;">
                        Import Settings
                        <InputFile OnChange="ImportSettings" style="display: none;" accept=".json" />
                    </label>
                    @if (importResult is not null)
                    {
                        <span style="font-size: 0.8rem; color: @(importSuccess ? "var(--k-green)" : "var(--k-red)"); margin-left: 0.5rem;">@importResult</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="k-card" style="margin-bottom: 1.5rem;">
        <div class="k-card-header">
            Webhook Notifications
            <button class="k-btn" @onclick="SaveWebhook">Save</button>
        </div>
        <div class="k-card-body">
            <div style="max-width: 600px;">
                <label class="k-form-label">Webhook URL (Discord, Slack, or any HTTP endpoint)</label>
                <input class="k-form-input" type="text" placeholder="https://discord.com/api/webhooks/..." @bind="webhookUrl" />
                <div style="display: flex; gap: 1rem; margin-top: 0.5rem;">
                    <label style="font-size: 0.8rem; display: flex; align-items: center; gap: 0.3rem; color: var(--k-text-muted);">
                        <input type="checkbox" @bind="webhookEnabled" /> Enabled
                    </label>
                    <label style="font-size: 0.8rem; display: flex; align-items: center; gap: 0.3rem; color: var(--k-text-muted);">
                        <input type="checkbox" @bind="webhookOnCrash" /> On Crash
                    </label>
                    <label style="font-size: 0.8rem; display: flex; align-items: center; gap: 0.3rem; color: var(--k-text-muted);">
                        <input type="checkbox" @bind="webhookOnRestart" /> On Restart Loop
                    </label>
                </div>
                <span style="font-size: 0.7rem; color: var(--k-text-muted);">Auto-detects Discord and Slack URLs. Other URLs receive a generic JSON POST.</span>
            </div>
        </div>
    </div>

    <div class="k-card" style="margin-bottom: 1.5rem;">
        <div class="k-card-header">
            Scheduled Restarts
            <button class="k-btn" @onclick="ShowAddSchedule">Add Schedule</button>
        </div>
        @if (showScheduleForm)
        {
            <div class="k-card-body" style="border-bottom: 1px solid var(--k-border);">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; max-width: 500px;">
                    <div>
                        <label class="k-form-label">Container Name</label>
                        <input class="k-form-input" type="text" placeholder="my-container" @bind="schedContainerName" />
                    </div>
                    <div>
                        <label class="k-form-label">Schedule</label>
                        <select class="k-form-input" @bind="schedPreset">
                            <option value="03:00">Daily at 3:00 AM</option>
                            <option value="06:00">Daily at 6:00 AM</option>
                            <option value="00:00">Daily at Midnight</option>
                            <option value="Sun 03:00">Sunday at 3:00 AM</option>
                            <option value="Mon 03:00">Monday at 3:00 AM</option>
                            <option value="Mon,Wed,Fri 03:00">Mon/Wed/Fri at 3:00 AM</option>
                            <option value="*/6">Every 6 hours</option>
                            <option value="*/12">Every 12 hours</option>
                            <option value="custom">Custom...</option>
                        </select>
                    </div>
                    @if (schedPreset == "custom")
                    {
                        <div style="grid-column: span 2;">
                            <label class="k-form-label">Custom Expression (e.g. "Sun 03:00" or "*/8")</label>
                            <input class="k-form-input" type="text" placeholder="HH:mm or Day HH:mm or */N" @bind="schedCustom" />
                        </div>
                    }
                </div>
                <div style="display: flex; gap: 0.5rem; margin-top: 0.75rem;">
                    <button class="k-btn k-btn-primary" @onclick="SaveSchedule" disabled="@(string.IsNullOrWhiteSpace(schedContainerName))">Save</button>
                    <button class="k-btn" @onclick="() => showScheduleForm = false">Cancel</button>
                </div>
            </div>
        }
        @if (schedules.Count > 0)
        {
            <table class="k-table">
                <thead><tr><th>Container</th><th>Schedule</th><th>Enabled</th><th style="text-align: right;">Actions</th></tr></thead>
                <tbody>
                    @foreach (var sr in schedules)
                    {
                        <tr>
                            <td><strong>@sr.ContainerName</strong></td>
                            <td class="k-mono">@sr.CronExpression</td>
                            <td>
                                <span style="color: @(sr.Enabled ? "var(--k-green)" : "var(--k-text-muted)");">@(sr.Enabled ? "Active" : "Disabled")</span>
                            </td>
                            <td style="text-align: right;">
                                <button class="k-btn k-btn-danger" @onclick="() => DeleteSchedule(sr.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else if (!showScheduleForm)
        {
            <div style="text-align: center; padding: 1.5rem; color: var(--k-text-muted);">No scheduled restarts configured.</div>
        }
    </div>

    <div class="k-card">
        <div class="k-card-header">About Authentication</div>
        <div class="k-card-body" style="font-size: 0.85rem; color: var(--k-text-muted); line-height: 1.6;">
            <p style="margin: 0 0 0.5rem;">SSH passwords are encrypted using ASP.NET Data Protection and stored locally. They never leave this server.</p>
            <p style="margin: 0 0 0.5rem;">To enable login protection for Kontainr itself, set these environment variables on the container:</p>
            <code class="k-mono" style="display: block; padding: 0.5rem; background: var(--k-bg); border-radius: 4px;">
                Auth__Username=youruser<br/>
                Auth__Password=yourpassword
            </code>
        </div>
    </div>
</div>

@code {
    private string hostUrl = "localhost";
    private List<SshConnectionConfig> connections = [];
    private bool showForm;
    private string? editId;
    private string editName = "", editHost = "", editUsername = "", editPassword = "", editInitCommands = "";
    private int editPort = 22;
    private string testResult = "";
    private string? importResult;
    private bool importSuccess;

    // Webhook
    private string webhookUrl = "";
    private bool webhookEnabled;
    private bool webhookOnCrash = true;
    private bool webhookOnRestart = true;

    // Scheduled restarts
    private List<ScheduledRestart> schedules = [];
    private bool showScheduleForm;
    private string schedContainerName = "";
    private string schedPreset = "03:00";
    private string schedCustom = "";
    private bool testSuccess;
    private bool testing;

    private bool confirmVisible;
    private string confirmTitle = "", confirmMessage = "", confirmBtnText = "Confirm";
    private Func<Task>? pendingAction;
    private void ShowConfirm(string t, string m, string b, Func<Task> a) { confirmTitle = t; confirmMessage = m; confirmBtnText = b; pendingAction = a; confirmVisible = true; }
    private async Task ConfirmAction() { confirmVisible = false; if (pendingAction is not null) await pendingAction(); pendingAction = null; }
    private void CancelConfirm() { confirmVisible = false; pendingAction = null; }

    protected override void OnInitialized()
    {
        hostUrl = SshSettings.GetHostUrl();
        LoadConnections();
        var wh = SshSettings.GetWebhook();
        webhookUrl = wh.Url; webhookEnabled = wh.Enabled;
        webhookOnCrash = wh.OnCrash; webhookOnRestart = wh.OnRestartLoop;
        schedules = SshSettings.GetScheduledRestarts();
    }

    private void SaveWebhook()
    {
        SshSettings.SaveWebhook(new WebhookConfig
        {
            Url = webhookUrl.Trim(), Enabled = webhookEnabled,
            OnCrash = webhookOnCrash, OnRestartLoop = webhookOnRestart
        });
        Toast.Success("Webhook settings saved");
    }

    private void ShowAddSchedule() { showScheduleForm = true; schedContainerName = ""; schedPreset = "03:00"; schedCustom = ""; }

    private void SaveSchedule()
    {
        var expr = schedPreset == "custom" ? schedCustom.Trim() : schedPreset;
        if (string.IsNullOrWhiteSpace(schedContainerName) || string.IsNullOrWhiteSpace(expr)) return;
        SshSettings.SaveScheduledRestart(new ScheduledRestart
        {
            ContainerName = schedContainerName.Trim(),
            CronExpression = expr,
            DisplaySchedule = expr,
            Enabled = true
        });
        Toast.Success("Schedule saved");
        showScheduleForm = false;
        schedules = SshSettings.GetScheduledRestarts();
    }

    private void DeleteSchedule(string id)
    {
        SshSettings.DeleteScheduledRestart(id);
        Toast.Success("Schedule deleted");
        schedules = SshSettings.GetScheduledRestarts();
    }

    private void SaveHostUrl()
    {
        SshSettings.SetHostUrl(hostUrl);
        Toast.Success("Host URL saved");
    }

    private void LoadConnections() => connections = SshSettings.GetConnections();

    private void ShowAddForm()
    {
        editId = null; editName = ""; editHost = ""; editPort = 22; editUsername = ""; editPassword = ""; editInitCommands = "";
        testResult = ""; showForm = true;
    }

    private void EditConnection(SshConnectionConfig conn)
    {
        editId = conn.Id; editName = conn.Name; editHost = conn.Host;
        editPort = conn.Port; editUsername = conn.Username; editPassword = "";
        editInitCommands = string.Join(", ", conn.InitCommands);
        testResult = ""; showForm = true;
    }

    private void CancelForm() { showForm = false; testResult = ""; }

    private void SaveConnection()
    {
        var config = new SshConnectionConfig
        {
            Id = editId ?? Guid.NewGuid().ToString("N")[..8],
            Name = editName.Trim(),
            Host = editHost.Trim(),
            Port = editPort,
            Username = editUsername.Trim(),
            InitCommands = string.IsNullOrWhiteSpace(editInitCommands)
                ? []
                : editInitCommands.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList()
        };

        string? password = string.IsNullOrEmpty(editPassword) ? null : editPassword;
        SshSettings.SaveConnection(config, password);
        Toast.Success(editId is not null ? "Connection updated" : "Connection saved");
        showForm = false;
        LoadConnections();
    }

    private void RequestDelete(SshConnectionConfig conn) =>
        ShowConfirm("Delete Connection", $"Delete SSH connection \"{conn.Name}\"?", "Delete", () =>
        {
            SshSettings.DeleteConnection(conn.Id);
            Toast.Success("Connection deleted");
            LoadConnections();
            return Task.CompletedTask;
        });

    private async Task TestConnection()
    {
        testing = true; testResult = "Connecting..."; testSuccess = false;
        StateHasChanged();

        try
        {
            var password = editPassword;
            if (string.IsNullOrEmpty(password) && editId is not null)
            {
                var existing = SshSettings.GetConnection(editId);
                if (existing is not null)
                    password = SshSettings.DecryptPassword(existing.EncryptedPassword);
            }

            await Task.Run(() =>
            {
                using var client = new Renci.SshNet.SshClient(editHost.Trim(), editPort, editUsername.Trim(), password ?? "");
                client.ConnectionInfo.Timeout = TimeSpan.FromSeconds(5);
                client.Connect();
                client.Disconnect();
            });

            testResult = "Connection successful!";
            testSuccess = true;
        }
        catch (Exception ex)
        {
            testResult = $"Failed: {ex.Message}";
            testSuccess = false;
        }
        testing = false;
    }

    private async Task ExportSettings()
    {
        var json = SshSettings.ExportSettings();
        await JS.InvokeVoidAsync("kontainr.downloadText", $"kontainr-settings-{DateTime.Now:yyyyMMdd}.json", json);
        Toast.Success("Settings exported");
    }

    private async Task ImportSettings(InputFileChangeEventArgs e)
    {
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(maxAllowedSize: 1024 * 1024));
            var json = await reader.ReadToEndAsync();
            SshSettings.ImportSettings(json);
            LoadConnections();
            hostUrl = SshSettings.GetHostUrl();
            importResult = "Import successful!";
            importSuccess = true;
            Toast.Success("Settings imported");
        }
        catch (Exception ex)
        {
            importResult = $"Import failed: {ex.Message}";
            importSuccess = false;
        }
    }
}
