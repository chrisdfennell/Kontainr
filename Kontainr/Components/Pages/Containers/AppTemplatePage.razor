@page "/templates"
@rendermode InteractiveServer
@using global::Docker.DotNet.Models
@inject DockerService Docker
@inject ToastService Toast

<PageTitle>App Templates - Kontainr</PageTitle>

<div class="k-topbar">
    <h1>App Templates</h1>
    <p style="font-size: 0.78rem; color: var(--k-text-muted); margin: 0;">Deploy popular Docker apps with one click.</p>
    <div style="display: flex; gap: 0.75rem; align-items: center;">
        <select class="k-select" @bind="categoryFilter">
            <option value="">All Categories</option>
            @foreach (var cat in categories)
            {
                <option value="@cat">@cat</option>
            }
        </select>
        <input class="k-search" type="text" placeholder="Search templates..." @bind="search" @bind:event="oninput" />
    </div>
</div>

<div class="k-content">
    @if (error is not null)
    {
        <div class="k-error">@error</div>
    }

    @* ── Config dialog before deploy ── *@
    @if (selectedTemplate is not null)
    {
        <div class="k-modal-overlay">
            <div class="k-modal" style="width: 550px;">
                <div class="k-modal-header">Deploy @selectedTemplate.Name</div>
                <div class="k-modal-body">
                    <div style="margin-bottom: 0.75rem;">
                        <label class="k-form-label">Container Name</label>
                        <input class="k-form-input" type="text" @bind="configName" />
                    </div>

                    @if (configPorts.Count > 0)
                    {
                        <div style="margin-bottom: 0.75rem;">
                            <label class="k-form-label">Port Mappings (Host : Container)</label>
                            @for (int i = 0; i < configPorts.Count; i++)
                            {
                                var idx = i;
                                <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.35rem;">
                                    <input class="k-form-input" style="width: 90px;" type="text" @bind="configPorts[idx].Host" />
                                    <span style="color: var(--k-text-muted);">:</span>
                                    <input class="k-form-input" style="width: 90px;" type="text" @bind="configPorts[idx].Container" disabled />
                                    <span class="k-mono" style="font-size: 0.75rem; color: var(--k-text-muted);">tcp</span>
                                </div>
                            }
                        </div>
                    }

                    @if (configEnv.Count > 0)
                    {
                        <div style="margin-bottom: 0.75rem;">
                            <label class="k-form-label">Environment Variables</label>
                            @for (int i = 0; i < configEnv.Count; i++)
                            {
                                var idx = i;
                                <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.35rem;">
                                    <input class="k-form-input" style="width: 180px;" type="text" @bind="configEnv[idx].Key" disabled />
                                    <span style="color: var(--k-text-muted);">=</span>
                                    <input class="k-form-input" style="flex: 1;" type="text" @bind="configEnv[idx].Value" />
                                </div>
                            }
                        </div>
                    }

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem;">
                        <div>
                            <label class="k-form-label">Network</label>
                            <select class="k-form-input" @bind="configNetwork">
                                <option value="">(default bridge)</option>
                                @foreach (var net in availableNetworks)
                                {
                                    <option value="@net">@net</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="k-form-label">Restart Policy</label>
                            <select class="k-form-input" @bind="configRestartPolicy">
                                <option value="unless-stopped">Unless Stopped</option>
                                <option value="always">Always</option>
                                <option value="on-failure">On Failure</option>
                                <option value="no">No</option>
                            </select>
                        </div>
                    </div>

                    <div style="margin-bottom: 0.75rem;">
                        <label class="k-form-label">
                            Volume Mounts
                            <button class="k-btn" style="font-size: 0.65rem; padding: 0.1rem 0.4rem; margin-left: 0.5rem;" @onclick="AddVolume">+ Add</button>
                        </label>
                        @for (int i = 0; i < configVolumes.Count; i++)
                        {
                            var idx = i;
                            <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.35rem;">
                                <input class="k-form-input" style="flex: 1;" type="text" placeholder="host path or volume name" @bind="configVolumes[idx].Host" />
                                <span style="color: var(--k-text-muted);">:</span>
                                <input class="k-form-input" style="flex: 1;" type="text" placeholder="container path" @bind="configVolumes[idx].Container" />
                                <button class="k-btn k-btn-danger" style="padding: 0.2rem 0.4rem; font-size: 0.7rem;" @onclick="() => configVolumes.RemoveAt(idx)">x</button>
                            </div>
                        }
                        @if (configVolumes.Count == 0)
                        {
                            <span style="font-size: 0.7rem; color: var(--k-text-muted);">No volumes configured. Click + Add to mount host paths or named volumes.</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(deployStatus))
                    {
                        <div class="k-pull-status" style="margin-top: 0.75rem;">@deployStatus</div>
                    }
                </div>
                <div class="k-modal-footer">
                    <button class="k-btn" @onclick="CancelConfig" disabled="@deploying">Cancel</button>
                    <button class="k-btn k-btn-primary" @onclick="DeployConfigured" disabled="@deploying">
                        @(deploying ? "Deploying..." : "Deploy")
                    </button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(deployStatus) && selectedTemplate is null)
    {
        <div class="k-pull-status" style="margin-bottom: 1rem;">@deployStatus</div>
    }

    <div class="k-template-grid">
        @foreach (var tmpl in FilteredTemplates)
        {
            <div class="k-template-card">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <div>
                        <div class="k-template-name">@tmpl.Name</div>
                        <div class="k-template-category">@tmpl.Category</div>
                    </div>
                    @if (!string.IsNullOrEmpty(tmpl.Url))
                    {
                        <a href="@tmpl.Url" target="_blank" rel="noopener noreferrer" class="k-btn" style="padding: 0.2rem 0.4rem; font-size: 0.65rem; text-decoration: none;" title="View on Docker Hub" @onclick:stopPropagation="true">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                            Hub
                        </a>
                    }
                </div>
                <div class="k-mono" style="font-size: 0.72rem; color: var(--k-text-muted); margin: 0.4rem 0;">@tmpl.Image</div>
                @if (tmpl.Ports.Count > 0)
                {
                    <div style="margin-bottom: 0.5rem;">
                        @foreach (var p in tmpl.Ports)
                        {
                            <span class="k-port-link" style="cursor: default;">@p.Host:@p.Container</span>
                        }
                    </div>
                }
                @if (tmpl.Env.Count > 0)
                {
                    <div style="font-size: 0.7rem; color: var(--k-text-muted); margin-bottom: 0.5rem;">
                        @tmpl.Env.Count env var(s)
                    </div>
                }
                <button class="k-btn k-btn-primary" style="width: 100%;" @onclick="() => ShowConfig(tmpl)">
                    Deploy
                </button>
            </div>
        }
    </div>

    @if (!FilteredTemplates.Any())
    {
        <div style="text-align: center; padding: 3rem; color: var(--k-text-muted);">No templates match your search.</div>
    }

    <div style="text-align: center; padding: 1rem; color: var(--k-text-muted); font-size: 0.8rem;">
        @FilteredTemplates.Count() of @AppTemplates.Templates.Count templates
    </div>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private string search = "";
    private string categoryFilter = "";
    private string? error;
    private string deployStatus = "";
    private bool deploying;

    // Config dialog state
    private AppTemplate? selectedTemplate;
    private string configName = "";
    private List<PortConfig> configPorts = [];
    private List<EnvConfig> configEnv = [];
    private List<VolumeConfig> configVolumes = [];
    private string configNetwork = "";
    private string configRestartPolicy = "unless-stopped";
    private List<string> availableNetworks = [];

    private List<string> categories = AppTemplates.Templates
        .Select(t => t.Category).Distinct().OrderBy(c => c).ToList();

    private IEnumerable<AppTemplate> FilteredTemplates
    {
        get
        {
            var result = AppTemplates.Templates.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(categoryFilter))
                result = result.Where(t => t.Category == categoryFilter);
            if (!string.IsNullOrWhiteSpace(search))
                result = result.Where(t =>
                    t.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    t.Category.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    t.Image.Contains(search, StringComparison.OrdinalIgnoreCase));
            return result;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var networks = await Docker.GetNetworksAsync();
            availableNetworks = networks
                .Select(n => n.Name)
                .Where(n => n != "none" && n != "host")
                .OrderBy(n => n)
                .ToList();
        }
        catch { }
    }

    private void ShowConfig(AppTemplate tmpl)
    {
        selectedTemplate = tmpl;
        configName = tmpl.Name.ToLowerInvariant().Replace(" ", "-");
        configPorts = tmpl.Ports.Select(p => new PortConfig { Host = p.Host, Container = p.Container }).ToList();
        configEnv = tmpl.Env.Select(e => new EnvConfig { Key = e.Key, Value = e.Value }).ToList();
        configVolumes = [];
        configNetwork = "";
        configRestartPolicy = tmpl.RestartPolicy;
        deployStatus = "";
    }

    private void AddVolume() => configVolumes.Add(new VolumeConfig());

    private void CancelConfig()
    {
        if (!deploying) { selectedTemplate = null; deployStatus = ""; }
    }

    private async Task DeployConfigured()
    {
        if (selectedTemplate is null) return;
        deploying = true;
        error = null;
        deployStatus = $"Pulling {selectedTemplate.Image}...";
        StateHasChanged();

        try
        {
            var imgParts = selectedTemplate.Image.Split(':', 2);
            await Docker.PullImageAsync(imgParts[0], imgParts.Length > 1 ? imgParts[1] : "latest",
                status => { deployStatus = status; InvokeAsync(StateHasChanged); });

            var exposedPorts = new Dictionary<string, EmptyStruct>();
            var portBindings = new Dictionary<string, IList<PortBinding>>();
            foreach (var p in configPorts.Where(p => !string.IsNullOrWhiteSpace(p.Container)))
            {
                var key = $"{p.Container}/tcp";
                exposedPorts[key] = default;
                portBindings[key] = [new PortBinding { HostPort = p.Host }];
            }

            var env = configEnv
                .Where(e => !string.IsNullOrWhiteSpace(e.Key))
                .Select(e => $"{e.Key}={e.Value}").ToList();

            var rpKind = configRestartPolicy switch
            {
                "always" => RestartPolicyKind.Always,
                "unless-stopped" => RestartPolicyKind.UnlessStopped,
                "on-failure" => RestartPolicyKind.OnFailure,
                _ => RestartPolicyKind.No
            };

            var binds = configVolumes
                .Where(v => !string.IsNullOrWhiteSpace(v.Host) && !string.IsNullOrWhiteSpace(v.Container))
                .Select(v => $"{v.Host.Trim()}:{v.Container.Trim()}")
                .ToList();

            deployStatus = "Creating container...";
            StateHasChanged();

            var result = await Docker.CreateContainerAsync(new CreateContainerParameters
            {
                Image = selectedTemplate.Image,
                Name = string.IsNullOrWhiteSpace(configName) ? null : configName.Trim(),
                Env = env,
                ExposedPorts = exposedPorts.Count > 0 ? exposedPorts : null,
                HostConfig = new HostConfig
                {
                    PortBindings = portBindings.Count > 0 ? portBindings : null,
                    RestartPolicy = new RestartPolicy { Name = rpKind },
                    Binds = binds.Count > 0 ? binds : null,
                    NetworkMode = !string.IsNullOrEmpty(configNetwork) ? configNetwork : null
                }
            });

            deployStatus = "Starting...";
            StateHasChanged();
            await Docker.StartContainerAsync(result.ID);

            Toast.Success($"{selectedTemplate.Name} deployed!");
            selectedTemplate = null;
            deployStatus = "";
            Nav.NavigateTo($"/containers/local/{result.ID}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
            deployStatus = "";
            Toast.Error($"Failed to deploy {selectedTemplate?.Name}");
        }

        deploying = false;
    }

    private class PortConfig { public string Host { get; set; } = ""; public string Container { get; set; } = ""; }
    private class EnvConfig { public string Key { get; set; } = ""; public string Value { get; set; } = ""; }
    private class VolumeConfig { public string Host { get; set; } = ""; public string Container { get; set; } = ""; }
}
