@page "/containers"
@rendermode InteractiveServer
@inject DockerService Docker
@inject DockerServiceFactory DockerFactory
@inject ToastService Toast
@inject SshSettingsService Settings
@inject StatsHistoryService StatsHistory
@implements IDisposable

<PageTitle>Containers - Kontainr</PageTitle>

<ConfirmDialog Title="@confirmTitle" Message="@confirmMessage" ConfirmText="@confirmBtnText"
               Visible="@confirmVisible" OnConfirm="ConfirmAction" OnCancel="CancelConfirm" />

<div class="k-topbar">
    <h1>Containers</h1>
    <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
        <input class="k-search" type="text" placeholder="Search containers..." @bind="searchTerm" @bind:event="oninput" />
        @if (allHostIds.Count > 1)
        {
            <select class="k-select" @bind="selectedHostId" @bind:after="LoadAsync">
                <option value="">All Hosts</option>
                @foreach (var h in hostConfigs)
                {
                    <option value="@h.Id">@h.Name</option>
                }
            </select>
        }
        <label style="font-size: 0.8rem; display: flex; align-items: center; gap: 0.4rem; color: var(--k-text-muted);">
            <input type="checkbox" @bind="showAll" @bind:after="LoadAsync" /> Show stopped
        </label>
        <span class="k-auto-refresh-indicator @(autoRefresh ? "active" : "")"></span>
        <label style="font-size: 0.8rem; display: flex; align-items: center; gap: 0.4rem; color: var(--k-text-muted);">
            <input type="checkbox" @bind="autoRefresh" @bind:after="ToggleAutoRefresh" /> Auto
        </label>
        <select class="k-select" @bind="refreshInterval" @bind:after="ToggleAutoRefresh" disabled="@(!autoRefresh)">
            <option value="3">3s</option>
            <option value="5">5s</option>
            <option value="10">10s</option>
            <option value="30">30s</option>
        </select>
        <a href="/containers/create" class="k-btn k-btn-primary" style="text-decoration: none;">Create</a>
        <button class="k-btn" @onclick="LoadAsync" disabled="@loading">Refresh</button>
    </div>
</div>

<div class="k-content">
    @if (error is not null)
    {
        <div class="k-error">@error</div>
    }

    @if (loading && allContainers.Count == 0)
    {
        <div class="k-spinner">Loading...</div>
    }
    else
    {
        @if (composeGroups.Count > 0)
        {
            @foreach (var group in composeGroups)
            {
                var allRunning = group.Value.All(c => c.IsRunning);
                var anyRunning = group.Value.Any(c => c.IsRunning);
                <div class="k-card" style="margin-bottom: 1rem;">
                    <div class="k-group-header">
                        <div style="display: flex; align-items: center; gap: 0.5rem; flex: 1; cursor: pointer;" @onclick="() => ToggleGroup(group.Key)">
                            <svg class="k-group-chevron @(IsCollapsed(group.Key) ? "collapsed" : "")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><polyline points="7 7 7 3 17 3 17 7"/></svg>
                            @group.Key
                            <span class="k-badge">@group.Value.Count containers</span>
                        </div>
                        <div class="k-btn-group" @onclick:stopPropagation="true">
                            @if (anyRunning)
                            {
                                <button class="k-btn" @onclick="() => BulkStopGroup(group.Key)" disabled="@(bulkAction is not null)" title="Stop all">Stop All</button>
                                <button class="k-btn" @onclick="() => BulkRestartGroup(group.Key)" disabled="@(bulkAction is not null)" title="Restart all">Restart All</button>
                            }
                            @if (!allRunning)
                            {
                                <button class="k-btn k-btn-success" @onclick="() => BulkStartGroup(group.Key)" disabled="@(bulkAction is not null)" title="Start all">Start All</button>
                            }
                        </div>
                    </div>
                    @if (!IsCollapsed(group.Key))
                    {
                        @RenderContainerTable(group.Value)
                    }
                </div>
            }
        }

        @if (standaloneContainers.Count > 0)
        {
            <div class="k-card" style="margin-bottom: 1rem;">
                @if (composeGroups.Count > 0)
                {
                    <div class="k-card-header">Standalone Containers</div>
                }
                @RenderContainerTable(standaloneContainers)
            </div>
        }

        @if (composeGroups.Count == 0 && standaloneContainers.Count == 0)
        {
            <div style="text-align: center; padding: 3rem; color: var(--k-text-muted);">No containers found.</div>
        }
    }
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private List<ContainerViewModel> allContainers = [];
    private Dictionary<string, List<ContainerViewModel>> composeGroups = [];
    private List<ContainerViewModel> standaloneContainers = [];
    private Dictionary<string, (double cpu, long memUsage, long memLimit)> stats = [];
    private HashSet<string> collapsedGroups = [];
    private IReadOnlyList<string> allHostIds = [];
    private IReadOnlyList<Models.DockerHostConfig> hostConfigs = [];
    private string selectedHostId = "";
    private bool loading = true;
    private bool showAll = true;
    private string searchTerm = "";
    private string? error;
    private string? actionInProgress;
    private string? bulkAction;
    private bool autoRefresh = true;
    private int refreshInterval = 5;
    private Timer? refreshTimer;
    private string hostUrl = "localhost";
    private bool multiHost;

    // Confirm dialog
    private bool confirmVisible;
    private string confirmTitle = "";
    private string confirmMessage = "";
    private string confirmBtnText = "Confirm";
    private Func<Task>? pendingAction;

    protected override async Task OnInitializedAsync()
    {
        hostUrl = Settings.GetHostUrl();
        allHostIds = DockerFactory.GetAllHostIds();
        hostConfigs = DockerFactory.GetAllHostConfigs();
        multiHost = allHostIds.Count > 1;
        await LoadAsync();
        StartAutoRefresh();
    }

    private IEnumerable<ContainerViewModel> Filtered =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? allContainers
            : allContainers.Where(c =>
                c.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                c.Image.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (c.ComposeProject?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    private async Task LoadAsync()
    {
        loading = true;
        error = null;
        try
        {
            var all = new List<ContainerViewModel>();
            var hostsToQuery = string.IsNullOrEmpty(selectedHostId) ? allHostIds : [selectedHostId];

            foreach (var hostId in hostsToQuery)
            {
                try
                {
                    var docker = DockerFactory.GetService(hostId);
                    var config = DockerFactory.GetHostConfig(hostId);
                    var raw = await docker.GetContainersAsync(showAll);
                    all.AddRange(raw.Select(c => ContainerViewModel.FromApi(c, hostId, config.Name)));
                }
                catch (Exception ex)
                {
                    error = (error is null ? "" : error + "\n") + $"{hostId}: {ex.Message}";
                }
            }

            allContainers = all.OrderBy(c => c.Name).ToList();
            RebuildGroups();

            var running = allContainers.Where(c => c.IsRunning).ToList();
            var statsTasks = running.Select(async c =>
            {
                var docker = DockerFactory.GetService(c.HostId);
                var s = await docker.GetContainerStatsOnceAsync(c.Id);
                return (c.Id, c.HostId, Stats: s);
            });
            var results = await Task.WhenAll(statsTasks);
            var newStats = new Dictionary<string, (double cpu, long memUsage, long memLimit)>();
            foreach (var r in results)
            {
                if (r.Stats is not null)
                {
                    double cpu = 0;
                    var cpuDelta = (double)(r.Stats.CPUStats.CPUUsage.TotalUsage - r.Stats.PreCPUStats.CPUUsage.TotalUsage);
                    var sysDelta = (double)(r.Stats.CPUStats.SystemUsage - r.Stats.PreCPUStats.SystemUsage);
                    var cpuCount = r.Stats.CPUStats.OnlineCPUs > 0 ? r.Stats.CPUStats.OnlineCPUs : (ulong)(r.Stats.CPUStats.CPUUsage.PercpuUsage?.Count ?? 1);
                    if (sysDelta > 0 && cpuDelta >= 0)
                        cpu = (cpuDelta / sysDelta) * cpuCount * 100.0;
                    var key = r.HostId == "local" ? r.Id : $"{r.HostId}:{r.Id}";
                    newStats[key] = (cpu, (long)r.Stats.MemoryStats.Usage, (long)r.Stats.MemoryStats.Limit);
                    StatsHistory.Record(key, cpu, (long)r.Stats.MemoryStats.Usage);
                }
            }
            stats = newStats;
        }
        catch (Exception ex)
        {
            error = $"Cannot connect to Docker: {ex.Message}";
        }
        loading = false;
    }

    private void RebuildGroups()
    {
        var filtered = Filtered.ToList();
        composeGroups = filtered
            .Where(c => c.ComposeProject is not null)
            .GroupBy(c => c.ComposeProject!)
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.OrderBy(c => c.Name).ToList());
        standaloneContainers = filtered
            .Where(c => c.ComposeProject is null)
            .OrderBy(c => c.Name)
            .ToList();
    }

    private void StartAutoRefresh()
    {
        refreshTimer?.Dispose();
        if (autoRefresh)
        {
            refreshTimer = new Timer(async _ =>
            {
                await InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
            }, null, TimeSpan.FromSeconds(refreshInterval), TimeSpan.FromSeconds(refreshInterval));
        }
    }

    private void ToggleAutoRefresh() => StartAutoRefresh();
    private void ToggleGroup(string key) { if (!collapsedGroups.Remove(key)) collapsedGroups.Add(key); }
    private bool IsCollapsed(string key) => collapsedGroups.Contains(key);

    private string GetCpu(ContainerViewModel c)
    {
        var key = c.HostId == "local" ? c.Id : $"{c.HostId}:{c.Id}";
        return stats.TryGetValue(key, out var s) ? $"{s.cpu:F1}%" : "...";
    }

    private string GetMemory(ContainerViewModel c)
    {
        var key = c.HostId == "local" ? c.Id : $"{c.HostId}:{c.Id}";
        return stats.TryGetValue(key, out var s) ? $"{FormatBytes(s.memUsage)} / {FormatBytes(s.memLimit)}" : "...";
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F0} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }

    // ── Confirm dialog helpers ───────────────────────────────────

    private void ShowConfirm(string title, string message, string btnText, Func<Task> action)
    {
        confirmTitle = title;
        confirmMessage = message;
        confirmBtnText = btnText;
        pendingAction = action;
        confirmVisible = true;
    }

    private async Task ConfirmAction()
    {
        confirmVisible = false;
        if (pendingAction is not null)
            await pendingAction();
        pendingAction = null;
    }

    private void CancelConfirm() { confirmVisible = false; pendingAction = null; }

    // ── Container actions ────────────────────────────────────────

    private async Task StartContainer(ContainerViewModel c)
    {
        actionInProgress = c.Id;
        try { var docker = DockerFactory.GetService(c.HostId); await docker.StartContainerAsync(c.Id); Toast.Success("Container started"); }
        catch (Exception ex) { Toast.Error($"Start failed: {ex.Message}"); }
        await LoadAsync();
        actionInProgress = null;
    }

    private void RequestStop(ContainerViewModel c) =>
        ShowConfirm("Stop Container", $"Stop container \"{c.Name}\"?", "Stop", async () => await StopContainer(c));

    private async Task StopContainer(ContainerViewModel c)
    {
        actionInProgress = c.Id;
        try { var docker = DockerFactory.GetService(c.HostId); await docker.StopContainerAsync(c.Id); Toast.Success("Container stopped"); }
        catch (Exception ex) { Toast.Error($"Stop failed: {ex.Message}"); }
        await LoadAsync();
        actionInProgress = null;
    }

    private async Task RestartContainer(ContainerViewModel c)
    {
        actionInProgress = c.Id;
        try { var docker = DockerFactory.GetService(c.HostId); await docker.RestartContainerAsync(c.Id); Toast.Success("Container restarted"); }
        catch (Exception ex) { Toast.Error($"Restart failed: {ex.Message}"); }
        await LoadAsync();
        actionInProgress = null;
    }

    // ── Bulk actions ─────────────────────────────────────────────

    private void BulkStartGroup(string project) =>
        ShowConfirm("Start Stack", $"Start all containers in \"{project}\"?", "Start All", async () =>
        {
            bulkAction = project;
            var containers = composeGroups.GetValueOrDefault(project) ?? [];
            foreach (var c in containers.Where(c => !c.IsRunning))
            {
                try { var docker = DockerFactory.GetService(c.HostId); await docker.StartContainerAsync(c.Id); }
                catch { }
            }
            Toast.Success($"Started stack: {project}");
            await LoadAsync();
            bulkAction = null;
        });

    private void BulkStopGroup(string project) =>
        ShowConfirm("Stop Stack", $"Stop all containers in \"{project}\"?", "Stop All", async () =>
        {
            bulkAction = project;
            var containers = composeGroups.GetValueOrDefault(project) ?? [];
            foreach (var c in containers.Where(c => c.IsRunning))
            {
                try { var docker = DockerFactory.GetService(c.HostId); await docker.StopContainerAsync(c.Id); }
                catch { }
            }
            Toast.Success($"Stopped stack: {project}");
            await LoadAsync();
            bulkAction = null;
        });

    private void BulkRestartGroup(string project) =>
        ShowConfirm("Restart Stack", $"Restart all containers in \"{project}\"?", "Restart All", async () =>
        {
            bulkAction = project;
            var containers = composeGroups.GetValueOrDefault(project) ?? [];
            foreach (var c in containers.Where(c => c.IsRunning))
            {
                try { var docker = DockerFactory.GetService(c.HostId); await docker.RestartContainerAsync(c.Id); }
                catch { }
            }
            Toast.Success($"Restarted stack: {project}");
            await LoadAsync();
            bulkAction = null;
        });

    private void NavigateToContainer(ContainerViewModel c) => Nav.NavigateTo($"/containers/{c.HostId}/{c.Id}");

    private RenderFragment RenderContainerTable(List<ContainerViewModel> items) => __builder =>
    {
        <table class="k-table">
            <thead>
                <tr>
                    <th class="col-name">Name</th>
                    <th class="col-image">Image</th>
                    <th class="col-status">Status</th>
                    @if (multiHost)
                    {
                        <th class="col-host">Host</th>
                    }
                    <th class="col-cpu">CPU</th>
                    <th class="col-mem">Memory</th>
                    <th class="col-ports">Ports</th>
                    <th class="col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in items)
                {
                    <tr class="k-clickable" @onclick="() => NavigateToContainer(c)">
                        <td class="col-name">
                            <strong>@c.Name</strong>
                            @if (Docker.IsSelf(c.Id))
                            {
                                <span class="k-badge" style="margin-left: 0.4rem; background: rgba(88,166,255,0.15); color: var(--k-accent); font-size: 0.65rem;">self</span>
                            }
                            @if (c.ComposeService is not null)
                            {
                                <br /><span style="font-size: 0.75rem; color: var(--k-text-muted);">service: @c.ComposeService</span>
                            }
                        </td>
                        <td class="col-image k-mono">@c.Image</td>
                        <td class="col-status">
                            <span class="k-status @c.StateClass">
                                <span class="k-status-dot"></span>
                                @c.Status
                            </span>
                            @if (c.HealthStatus is not null)
                            {
                                <span class="k-health-badge @c.HealthClass">@c.HealthStatus</span>
                            }
                        </td>
                        @if (multiHost)
                        {
                            <td class="col-host">@c.HostName</td>
                        }
                        <td class="col-cpu k-mono">@(c.IsRunning ? GetCpu(c) : "-")</td>
                        <td class="col-mem k-mono">@(c.IsRunning ? GetMemory(c) : "-")</td>
                        <td class="col-ports" @onclick:stopPropagation="true">
                            @if (c.PublicPorts.Any())
                            {
                                <div class="k-ports-cell">
                                    @foreach (var p in c.PublicPorts)
                                    {
                                        <a href="http://@(hostUrl):@p.PublicPort" target="_blank" class="k-port-link" title="Open in browser">@p.PublicPort:@p.PrivatePort/@p.Type</a>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="k-mono">-</span>
                            }
                        </td>
                        <td class="col-actions" @onclick:stopPropagation="true">
                            <div class="k-btn-group" style="justify-content: flex-end;">
                                @if (c.IsRunning)
                                {
                                    <button class="k-btn" @onclick="() => RequestStop(c)" disabled="@(actionInProgress == c.Id)" title="Stop">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="1"/></svg>
                                    </button>
                                    <button class="k-btn" @onclick="() => RestartContainer(c)" disabled="@(actionInProgress == c.Id)" title="Restart">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                                    </button>
                                }
                                else
                                {
                                    <button class="k-btn k-btn-success" @onclick="() => StartContainer(c)" disabled="@(actionInProgress == c.Id)" title="Start">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    };

    public void Dispose() => refreshTimer?.Dispose();
}
