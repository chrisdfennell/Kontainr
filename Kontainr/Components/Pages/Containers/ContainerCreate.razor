@page "/containers/create"
@rendermode InteractiveServer
@using global::Docker.DotNet.Models
@inject DockerService Docker
@inject ToastService Toast

<PageTitle>Create Container - Kontainr</PageTitle>

<div class="k-topbar">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
        <a href="/containers" class="k-btn" style="text-decoration: none;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back
        </a>
        <h1>Create Container</h1>
    </div>
</div>

<div class="k-content">
    @if (error is not null)
    {
        <div class="k-error">@error</div>
    }

    <div class="k-card" style="margin-bottom: 1rem;">
        <div class="k-card-header">Basic Configuration</div>
        <div class="k-card-body">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; max-width: 700px;">
                <div style="grid-column: span 2;">
                    <label class="k-form-label">Image *</label>
                    <input class="k-form-input" type="text" placeholder="e.g. nginx:latest, redis:7, ubuntu:24.04" @bind="image" />
                </div>
                <div>
                    <label class="k-form-label">Container Name</label>
                    <input class="k-form-input" type="text" placeholder="my-container (optional)" @bind="name" />
                </div>
                <div>
                    <label class="k-form-label">Restart Policy</label>
                    <select class="k-form-input" @bind="restartPolicy">
                        <option value="no">No</option>
                        <option value="always">Always</option>
                        <option value="unless-stopped">Unless Stopped</option>
                        <option value="on-failure">On Failure</option>
                    </select>
                </div>
                <div style="grid-column: span 2;">
                    <label class="k-form-label">Command Override</label>
                    <input class="k-form-input" type="text" placeholder="Optional: e.g. /bin/sh -c 'echo hello'" @bind="command" />
                </div>
            </div>
        </div>
    </div>

    <div class="k-card" style="margin-bottom: 1rem;">
        <div class="k-card-header">
            Port Mappings
            <button class="k-btn" @onclick="AddPort">Add Port</button>
        </div>
        <div class="k-card-body">
            @if (ports.Count == 0)
            {
                <span style="color: var(--k-text-muted); font-size: 0.85rem;">No port mappings configured.</span>
            }
            @for (int i = 0; i < ports.Count; i++)
            {
                var idx = i;
                <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
                    <input class="k-form-input" style="width: 100px;" type="text" placeholder="Host" @bind="ports[idx].Host" />
                    <span style="color: var(--k-text-muted);">:</span>
                    <input class="k-form-input" style="width: 100px;" type="text" placeholder="Container" @bind="ports[idx].Container" />
                    <select class="k-form-input" style="width: 80px;" @bind="ports[idx].Protocol">
                        <option value="tcp">TCP</option>
                        <option value="udp">UDP</option>
                    </select>
                    <button class="k-btn k-btn-danger" @onclick="() => ports.RemoveAt(idx)">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="k-card" style="margin-bottom: 1rem;">
        <div class="k-card-header">
            Volumes
            <button class="k-btn" @onclick="AddVolume">Add Volume</button>
        </div>
        <div class="k-card-body">
            @if (volumes.Count == 0)
            {
                <span style="color: var(--k-text-muted); font-size: 0.85rem;">No volumes configured.</span>
            }
            @for (int i = 0; i < volumes.Count; i++)
            {
                var idx = i;
                <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
                    <input class="k-form-input" style="flex: 1;" type="text" placeholder="Host path or volume name" @bind="volumes[idx].Source" />
                    <span style="color: var(--k-text-muted);">:</span>
                    <input class="k-form-input" style="flex: 1;" type="text" placeholder="Container path" @bind="volumes[idx].Destination" />
                    <label style="font-size: 0.75rem; color: var(--k-text-muted); display: flex; align-items: center; gap: 0.3rem;">
                        <input type="checkbox" @bind="volumes[idx].ReadOnly" /> RO
                    </label>
                    <button class="k-btn k-btn-danger" @onclick="() => volumes.RemoveAt(idx)">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="k-card" style="margin-bottom: 1rem;">
        <div class="k-card-header">
            Environment Variables
            <button class="k-btn" @onclick="AddEnv">Add Variable</button>
        </div>
        <div class="k-card-body">
            @if (envVars.Count == 0)
            {
                <span style="color: var(--k-text-muted); font-size: 0.85rem;">No environment variables configured.</span>
            }
            @for (int i = 0; i < envVars.Count; i++)
            {
                var idx = i;
                <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
                    <input class="k-form-input" style="width: 200px;" type="text" placeholder="KEY" @bind="envVars[idx].Key" />
                    <span style="color: var(--k-text-muted);">=</span>
                    <input class="k-form-input" style="flex: 1;" type="text" placeholder="value" @bind="envVars[idx].Value" />
                    <button class="k-btn k-btn-danger" @onclick="() => envVars.RemoveAt(idx)">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="k-card" style="margin-bottom: 1rem;">
        <div class="k-card-header">Resource Limits</div>
        <div class="k-card-body">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; max-width: 500px;">
                <div>
                    <label class="k-form-label">CPU Limit (cores, e.g. 0.5, 1, 2)</label>
                    <input class="k-form-input" type="number" step="0.1" min="0" placeholder="0 = unlimited" @bind="cpuLimit" />
                </div>
                <div>
                    <label class="k-form-label">Memory Limit (MB, e.g. 256, 512, 1024)</label>
                    <input class="k-form-input" type="number" min="0" placeholder="0 = unlimited" @bind="memoryLimitMb" />
                </div>
            </div>
        </div>
    </div>

    <div class="k-card" style="margin-bottom: 1rem;">
        <div class="k-card-header">Network</div>
        <div class="k-card-body">
            <div style="max-width: 350px;">
                <label class="k-form-label">Network</label>
                <select class="k-form-input" @bind="networkName">
                    <option value="">(default)</option>
                    @foreach (var net in availableNetworks)
                    {
                        <option value="@net">@net</option>
                    }
                </select>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(createStatus))
    {
        <div class="k-pull-status" style="margin-bottom: 1rem;">@createStatus</div>
    }

    <div style="display: flex; gap: 0.5rem;">
        <button class="k-btn k-btn-primary" style="padding: 0.5rem 1.5rem;" @onclick="Create"
                disabled="@(creating || string.IsNullOrWhiteSpace(image))">
            @(creating ? "Creating..." : "Create & Start")
        </button>
        <button class="k-btn" style="padding: 0.5rem 1.5rem;" @onclick="CreateOnly"
                disabled="@(creating || string.IsNullOrWhiteSpace(image))">
            Create Only
        </button>
    </div>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private string image = "";
    private string name = "";
    private string command = "";
    private string restartPolicy = "unless-stopped";
    private string networkName = "";
    private double cpuLimit;
    private long memoryLimitMb;
    private string? error;
    private string createStatus = "";
    private bool creating;
    private List<string> availableNetworks = [];

    private List<PortMapping> ports = [];
    private List<VolumeMapping> volumes = [];
    private List<EnvVar> envVars = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var nets = await Docker.GetNetworksAsync();
            availableNetworks = nets.Select(n => n.Name).OrderBy(n => n).ToList();
        }
        catch { }
    }

    private void AddPort() => ports.Add(new());
    private void AddVolume() => volumes.Add(new());
    private void AddEnv() => envVars.Add(new());

    private async Task Create() => await DoCreate(start: true);
    private async Task CreateOnly() => await DoCreate(start: false);

    private async Task DoCreate(bool start)
    {
        if (string.IsNullOrWhiteSpace(image)) return;
        creating = true;
        error = null;
        createStatus = "";

        try
        {
            // Pull image first
            var imgParts = image.Trim().Split(':', 2);
            var repo = imgParts[0];
            var tag = imgParts.Length > 1 ? imgParts[1] : "latest";

            createStatus = $"Pulling {repo}:{tag}...";
            StateHasChanged();

            await Docker.PullImageAsync(repo, tag, status =>
            {
                createStatus = status;
                InvokeAsync(StateHasChanged);
            });

            // Build port bindings
            var exposedPorts = new Dictionary<string, EmptyStruct>();
            var portBindings = new Dictionary<string, IList<PortBinding>>();

            foreach (var p in ports.Where(p => !string.IsNullOrWhiteSpace(p.Container)))
            {
                var containerPort = $"{p.Container}/{p.Protocol}";
                exposedPorts[containerPort] = default;
                portBindings[containerPort] =
                [
                    new PortBinding { HostPort = p.Host }
                ];
            }

            // Build volume binds
            var binds = volumes
                .Where(v => !string.IsNullOrWhiteSpace(v.Source) && !string.IsNullOrWhiteSpace(v.Destination))
                .Select(v => v.ReadOnly ? $"{v.Source}:{v.Destination}:ro" : $"{v.Source}:{v.Destination}")
                .ToList();

            // Build env
            var env = envVars
                .Where(e => !string.IsNullOrWhiteSpace(e.Key))
                .Select(e => $"{e.Key}={e.Value}")
                .ToList();

            // Restart policy
            var restartPol = new RestartPolicy
            {
                Name = restartPolicy switch
                {
                    "always" => RestartPolicyKind.Always,
                    "unless-stopped" => RestartPolicyKind.UnlessStopped,
                    "on-failure" => RestartPolicyKind.OnFailure,
                    _ => RestartPolicyKind.No
                }
            };

            // Parse command
            IList<string>? cmd = null;
            if (!string.IsNullOrWhiteSpace(command))
                cmd = command.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);

            createStatus = "Creating container...";
            StateHasChanged();

            var createParams = new CreateContainerParameters
            {
                Image = $"{repo}:{tag}",
                Name = string.IsNullOrWhiteSpace(name) ? null : name.Trim(),
                Cmd = cmd,
                Env = env,
                ExposedPorts = exposedPorts.Count > 0 ? exposedPorts : null,
                HostConfig = new HostConfig
                {
                    PortBindings = portBindings.Count > 0 ? portBindings : null,
                    Binds = binds.Count > 0 ? binds : null,
                    RestartPolicy = restartPol,
                    NetworkMode = string.IsNullOrEmpty(networkName) ? null : networkName,
                    NanoCPUs = cpuLimit > 0 ? (long)(cpuLimit * 1_000_000_000) : 0,
                    Memory = memoryLimitMb > 0 ? memoryLimitMb * 1024 * 1024 : 0
                }
            };

            var result = await Docker.CreateContainerAsync(createParams);

            if (start)
            {
                createStatus = "Starting container...";
                StateHasChanged();
                await Docker.StartContainerAsync(result.ID);
                Toast.Success($"Container '{(string.IsNullOrWhiteSpace(name) ? result.ID[..12] : name)}' created and started");
            }
            else
            {
                Toast.Success($"Container '{(string.IsNullOrWhiteSpace(name) ? result.ID[..12] : name)}' created");
            }

            Nav.NavigateTo($"/containers/local/{result.ID}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
            createStatus = "";
            Toast.Error("Failed to create container");
        }

        creating = false;
    }

    private class PortMapping
    {
        public string Host { get; set; } = "";
        public string Container { get; set; } = "";
        public string Protocol { get; set; } = "tcp";
    }

    private class VolumeMapping
    {
        public string Source { get; set; } = "";
        public string Destination { get; set; } = "";
        public bool ReadOnly { get; set; }
    }

    private class EnvVar
    {
        public string Key { get; set; } = "";
        public string Value { get; set; } = "";
    }
}
