@page "/images"
@rendermode InteractiveServer
@inject DockerService Docker
@inject ToastService Toast

<PageTitle>Images - Kontainr</PageTitle>

<ConfirmDialog Title="@confirmTitle" Message="@confirmMessage" ConfirmText="@confirmBtnText"
               Visible="@confirmVisible" OnConfirm="ConfirmAction" OnCancel="CancelConfirm" />

<div class="k-topbar">
    <h1>Images</h1>
    <div style="display: flex; gap: 0.75rem; align-items: center;">
        <input class="k-search" type="text" placeholder="Search images..." @bind="searchTerm" @bind:event="oninput" />
        <button class="k-btn k-btn-primary" @onclick="ShowPullDialog">Pull Image</button>
        <button class="k-btn k-btn-danger" @onclick="RequestPrune" disabled="@pruning">Prune</button>
        <button class="k-btn" @onclick="LoadAsync" disabled="@loading">Refresh</button>
    </div>
</div>

<div class="k-content">
    @if (error is not null)
    {
        <div class="k-error">@error</div>
    }

    @if (showPull)
    {
        <div class="k-card" style="margin-bottom: 1rem;">
            <div class="k-card-header">Pull Image</div>
            <div class="k-card-body">
                <div style="display: flex; gap: 0.75rem; align-items: flex-end;">
                    <div style="flex: 1;">
                        <label style="font-size: 0.75rem; color: var(--k-text-muted); display: block; margin-bottom: 0.25rem;">Image</label>
                        <input class="k-search" style="width: 100%;" type="text" placeholder="e.g. nginx, redis, ubuntu"
                               @bind="pullImage" @bind:event="oninput" />
                    </div>
                    <div style="width: 120px;">
                        <label style="font-size: 0.75rem; color: var(--k-text-muted); display: block; margin-bottom: 0.25rem;">Tag</label>
                        <input class="k-search" style="width: 100%;" type="text" placeholder="latest"
                               @bind="pullTag" @bind:event="oninput" />
                    </div>
                    <button class="k-btn k-btn-primary" @onclick="PullImage" disabled="@(pulling || string.IsNullOrWhiteSpace(pullImage))">
                        @(pulling ? "Pulling..." : "Pull")
                    </button>
                    <button class="k-btn" @onclick="() => showPull = false" disabled="@pulling">Cancel</button>
                </div>
                @if (!string.IsNullOrEmpty(pullStatus))
                {
                    <div class="k-pull-status">@pullStatus</div>
                }
            </div>
        </div>
    }

    @if (loading)
    {
        <div class="k-spinner">Loading...</div>
    }
    else
    {
        <div class="k-card">
            <table class="k-table">
                <thead>
                    <tr>
                        <th>Repository</th>
                        <th>Tag</th>
                        <th>ID</th>
                        <th>Size</th>
                        <th>Created</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var img in FilteredImages)
                    {
                        var repoTag = img.RepoTags?.FirstOrDefault() ?? "<none>:<none>";
                        var parts = repoTag.Split(':', 2);
                        var repo = parts[0];
                        var tag = parts.Length > 1 ? parts[1] : "latest";
                        <tr>
                            <td><strong>@repo</strong></td>
                            <td><span class="k-badge">@tag</span></td>
                            <td class="k-mono">@img.ID[7..19]</td>
                            <td>@FormatSize(img.Size)</td>
                            <td>@img.Created.ToLocalTime().ToString("g")</td>
                            <td style="text-align: right;">
                                <button class="k-btn k-btn-danger" @onclick="() => RequestRemoveImage(img.ID, repoTag)" disabled="@(removing == img.ID)" title="Remove">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!FilteredImages.Any())
        {
            <div style="text-align: center; padding: 3rem; color: var(--k-text-muted);">No images found.</div>
        }
    }
</div>

@code {
    private IList<Docker.DotNet.Models.ImagesListResponse> images = [];
    private bool loading = true;
    private string searchTerm = "";
    private string? error;
    private string? removing;
    private bool pruning;

    private bool showPull;
    private string pullImage = "";
    private string pullTag = "latest";
    private string pullStatus = "";
    private bool pulling;

    // Confirm
    private bool confirmVisible;
    private string confirmTitle = "", confirmMessage = "", confirmBtnText = "Confirm";
    private Func<Task>? pendingAction;
    private void ShowConfirm(string t, string m, string b, Func<Task> a) { confirmTitle = t; confirmMessage = m; confirmBtnText = b; pendingAction = a; confirmVisible = true; }
    private async Task ConfirmAction() { confirmVisible = false; if (pendingAction is not null) await pendingAction(); pendingAction = null; }
    private void CancelConfirm() { confirmVisible = false; pendingAction = null; }

    private IEnumerable<Docker.DotNet.Models.ImagesListResponse> FilteredImages =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? images
            : images.Where(i => i.RepoTags?.Any(t => t.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) == true);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        loading = true; error = null;
        try { images = await Docker.GetImagesAsync(); }
        catch (Exception ex) { error = $"Cannot connect to Docker: {ex.Message}"; }
        loading = false;
    }

    private void ShowPullDialog() { showPull = true; pullImage = ""; pullTag = "latest"; pullStatus = ""; }

    private async Task PullImage()
    {
        if (string.IsNullOrWhiteSpace(pullImage)) return;
        pulling = true; pullStatus = "Starting pull..."; error = null;
        try
        {
            await Docker.PullImageAsync(pullImage.Trim(), string.IsNullOrWhiteSpace(pullTag) ? "latest" : pullTag.Trim(),
                status => { pullStatus = status; InvokeAsync(StateHasChanged); });
            pullStatus = "Pull complete!";
            Toast.Success($"Pulled {pullImage}:{pullTag}");
            await LoadAsync();
        }
        catch (Exception ex) { pullStatus = $"Pull failed: {ex.Message}"; Toast.Error("Pull failed"); }
        pulling = false;
    }

    private void RequestRemoveImage(string id, string name) =>
        ShowConfirm("Remove Image", $"Remove image \"{name}\"?", "Remove", async () =>
        {
            removing = id;
            try { await Docker.RemoveImageAsync(id); Toast.Success("Image removed"); await LoadAsync(); }
            catch (Exception ex) { Toast.Error($"Failed to remove: {ex.Message}"); }
            removing = null;
        });

    private void RequestPrune() =>
        ShowConfirm("Prune Images", "Remove all dangling (unused) images? This cannot be undone.", "Prune", async () =>
        {
            pruning = true;
            try
            {
                var result = await Docker.PruneImagesAsync();
                var reclaimed = FormatSize((long)(result.SpaceReclaimed));
                Toast.Success($"Pruned images, reclaimed {reclaimed}");
                await LoadAsync();
            }
            catch (Exception ex) { Toast.Error($"Prune failed: {ex.Message}"); }
            pruning = false;
        });

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }
}
