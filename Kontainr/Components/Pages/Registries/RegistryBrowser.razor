@page "/registries/{RegistryId}/browse"
@rendermode InteractiveServer
@inject SshSettingsService Settings
@inject RegistryService Registry
@inject DockerService Docker
@inject ToastService Toast

<PageTitle>Browse Registry - Kontainr</PageTitle>

<div class="k-topbar">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
        <a href="/registries" class="k-btn" style="text-decoration: none;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back
        </a>
        <h1>@(config?.Name ?? "Registry")</h1>
    </div>
    <p style="font-size: 0.78rem; color: var(--k-text-muted); margin: 0;">Browse tags and images in a connected registry.</p>
</div>

<div class="k-content">
    @if (error is not null)
    {
        <div class="k-error">@error</div>
    }

    @if (selectedRepo is null)
    {
        <div class="k-card">
            <div class="k-card-header">
                Repositories
                <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <input class="k-form-input" type="text" placeholder="Filter..." @bind="repoFilter" @bind:event="oninput" style="width: 200px; font-size: 0.85rem;" />
                    <button class="k-btn" @onclick="LoadRepositories" disabled="@loading">
                        @(loading ? "Loading..." : "Refresh")
                    </button>
                </div>
            </div>

            @if (loading)
            {
                <div class="k-card-body"><div class="k-spinner">Loading repositories...</div></div>
            }
            else
            {
                <table class="k-table">
                    <thead>
                        <tr>
                            <th>Repository</th>
                            <th style="width: 100px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var repo in FilteredRepos)
                        {
                            <tr>
                                <td style="font-family: var(--k-font-mono); font-size: 0.85rem;">@repo</td>
                                <td>
                                    <button class="k-btn" @onclick="() => SelectRepo(repo)">Tags</button>
                                </td>
                            </tr>
                        }
                        @if (FilteredRepos.Count == 0)
                        {
                            <tr><td colspan="2" style="text-align: center; color: var(--k-text-muted); padding: 2rem;">
                                @(repositories.Count == 0 ? "No repositories found" : "No matches")
                            </td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
    else
    {
        <div class="k-card">
            <div class="k-card-header">
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <button class="k-btn" @onclick="() => { selectedRepo = null; tags = []; }">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    </button>
                    <span style="font-family: var(--k-font-mono);">@selectedRepo</span>
                </div>
            </div>

            @if (loadingTags)
            {
                <div class="k-card-body"><div class="k-spinner">Loading tags...</div></div>
            }
            else
            {
                <table class="k-table">
                    <thead>
                        <tr>
                            <th>Tag</th>
                            <th style="width: 200px;">Digest</th>
                            <th style="width: 100px;">Size</th>
                            <th style="width: 120px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tag in tags)
                        {
                            var detail = tagDetails.GetValueOrDefault(tag);
                            <tr>
                                <td style="font-family: var(--k-font-mono); font-size: 0.85rem;">@tag</td>
                                <td style="font-family: var(--k-font-mono); font-size: 0.8rem; color: var(--k-text-muted);">@(detail?.Digest ?? "—")</td>
                                <td style="font-family: var(--k-font-mono); font-size: 0.8rem; color: var(--k-text-muted);">@(detail is not null ? FormatSize(detail.Size) : "—")</td>
                                <td>
                                    <div class="k-btn-group">
                                        <button class="k-btn" style="font-size: 0.8rem;" @onclick="() => PullImage(tag)" disabled="@pulling">
                                            @(pulling && pullingTag == tag ? "Pulling..." : "Pull")
                                        </button>
                                        <button class="k-btn" style="font-size: 0.8rem;" @onclick="() => LoadTagDetail(tag)" title="Get details">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (tags.Count == 0)
                        {
                            <tr><td colspan="4" style="text-align: center; color: var(--k-text-muted); padding: 2rem;">No tags found</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        @if (!string.IsNullOrEmpty(pullOutput))
        {
            <div class="k-card" style="margin-top: 1rem;">
                <div class="k-card-header">Pull Output</div>
                <div class="k-log-viewer" style="max-height: 200px;">@pullOutput</div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public string RegistryId { get; set; } = "";

    private RegistryConfig? config;
    private List<string> repositories = [];
    private List<string> tags = [];
    private Dictionary<string, RegistryTagDetail> tagDetails = [];
    private string? selectedRepo;
    private string? error;
    private bool loading, loadingTags, pulling;
    private string pullingTag = "";
    private string pullOutput = "";
    private string repoFilter = "";

    private List<string> FilteredRepos => string.IsNullOrWhiteSpace(repoFilter)
        ? repositories
        : repositories.Where(r => r.Contains(repoFilter, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        config = Settings.GetRegistry(RegistryId);
        if (config is null)
        {
            error = "Registry not found";
            return;
        }
        await LoadRepositories();
    }

    private async Task LoadRepositories()
    {
        if (config is null) return;
        loading = true;
        error = null;
        try
        {
            repositories = await Registry.ListRepositoriesAsync(config);
        }
        catch (Exception ex)
        {
            error = $"Failed to load repositories: {ex.Message}";
        }
        loading = false;
    }

    private async Task SelectRepo(string repo)
    {
        selectedRepo = repo;
        loadingTags = true;
        tagDetails = [];
        tags = [];
        try
        {
            tags = await Registry.ListTagsAsync(config!, repo);
            tags.Reverse(); // newest first usually
        }
        catch (Exception ex)
        {
            error = $"Failed to load tags: {ex.Message}";
        }
        loadingTags = false;
    }

    private async Task LoadTagDetail(string tag)
    {
        try
        {
            var detail = await Registry.GetTagDetailAsync(config!, selectedRepo!, tag);
            tagDetails[tag] = detail;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Toast.Error($"Failed to load details: {ex.Message}");
        }
    }

    private async Task PullImage(string tag)
    {
        pulling = true;
        pullingTag = tag;
        pullOutput = "";

        try
        {
            var imageName = selectedRepo!;
            // For Docker Hub, images need the full path
            if (config!.Type == RegistryType.DockerHub)
            {
                // Already has namespace prefix from listing
            }
            else
            {
                // Prefix with registry URL
                var host = new Uri(config.Url).Host;
                imageName = $"{host}/{selectedRepo}";
            }

            var password = string.IsNullOrEmpty(config.EncryptedPassword) ? "" : Settings.DecryptPassword(config.EncryptedPassword);
            Docker.DotNet.Models.AuthConfig? auth = null;
            if (!string.IsNullOrEmpty(config.Username))
            {
                auth = new Docker.DotNet.Models.AuthConfig
                {
                    Username = config.Username,
                    Password = password,
                    ServerAddress = config.Type == RegistryType.DockerHub ? "https://index.docker.io/v1/" : config.Url
                };
            }

            await Docker.PullImageAsync(imageName, tag, msg =>
            {
                pullOutput += msg + "\n";
                InvokeAsync(StateHasChanged);
            }, auth);

            Toast.Success($"Pulled {imageName}:{tag}");
        }
        catch (Exception ex)
        {
            pullOutput += $"Error: {ex.Message}\n";
            Toast.Error($"Pull failed: {ex.Message}");
        }

        pulling = false;
        pullingTag = "";
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        0 => "—",
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        < 1024 * 1024 * 1024 => $"{bytes / (1024.0 * 1024):F1} MB",
        _ => $"{bytes / (1024.0 * 1024 * 1024):F1} GB"
    };
}
